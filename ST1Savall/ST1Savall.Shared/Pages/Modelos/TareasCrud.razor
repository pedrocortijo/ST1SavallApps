@page "/modelos/tareas"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Gestión de Tareas</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Tareas</h2>
            <p class="text-muted mb-0">Administración de tipos de tareas.</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (tareas == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando tareas...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@tareas"
                        KeyFieldName="IdTarea"
                        EditMode="GridEditMode.PopupEditForm"
                        CustomizeEditModel="OnCustomizeEditModel"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormCssClass="crud-popup"
                        PopupEditFormHeaderText="Formulario de tarea"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        SearchBoxNullText="Buscar tarea...">
                    <Columns>
                        <DxGridCommandColumn Width="120px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nueva Tarea">
                                    <i class="oi oi-plus me-1"></i> Nueva
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var tarea = (Tarea)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(tarea)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-info d-flex align-items-center justify-content-center shadow-sm"
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => DuplicarTareaAsync(tarea)"
                                                @onclick:stopPropagation
                                                title="Duplicar">
                                            <i class="oi oi-document" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(tarea)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="IdTarea" Caption="Código" Width="70px" />
                        <DxGridDataColumn FieldName="NombreTarea" Caption="Tarea (Descripción)" />
                        <DxGridDataColumn FieldName="Entrega1" Caption="Entrega {1]" Width="105px" />
                        <DxGridDataColumn FieldName="Entrega2" Caption="Entrega {2]" Width="105px" />
                        <DxGridDataColumn FieldName="Recoger1" Caption="Retirada {1]" Width="105px" />
                        <DxGridDataColumn FieldName="Recoger2" Caption="Retirada {2]" Width="105px" />
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var tarea = (Tarea)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3">
                            <DxFormLayoutItem Caption="Código" ColSpanMd="12">
                                <DxSpinEdit @bind-Value="@tarea.IdTarea" Enabled="false" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Tarea (Descripción)" ColSpanMd="12">
                                <DxTextBox @bind-Text="@tarea.NombreTarea" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-3 border-bottom pb-2 mb-2">Configuración de recogidas y entregas de contenedores
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3" BeginRow="true">
                                <div class="d-flex align-items-center gap-2 pt-2">
                                    <DxCheckBox @bind-Checked="@tarea.Entrega1" />
                                    <span>Entrega [1]</span>
                                </div>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3">
                                <div class="d-flex align-items-center gap-2 pt-2">
                                    <DxCheckBox @bind-Checked="@tarea.Entrega2" />
                                    <span>Entrega [2]</span>
                                </div>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3">
                                <div class="d-flex align-items-center gap-2 pt-2">
                                    <DxCheckBox @bind-Checked="@tarea.Recoger1" />
                                    <span>Retirada [1]</span>
                                </div>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3">
                                <div class="d-flex align-items-center gap-2 pt-2">
                                    <DxCheckBox @bind-Checked="@tarea.Recoger2" />
                                    <span>Retirada [2]</span>
                                </div>
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<Tarea>? tareas;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            tareas = await Http.GetFromJsonAsync<List<Tarea>>("api/tareas");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar tareas: {ex.Message}";
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (Tarea)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/tareas", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear tarea: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/tareas/{editModel.IdTarea}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar tarea: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task DuplicarTareaAsync(Tarea tarea)
    {
        try
        {
            await SetupHeadersAsync();
            var response = await Http.PostAsync($"api/tareas/{tarea.IdTarea}/duplicar", null);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al duplicar tarea: {response.ReasonPhrase}";
                return;
            }

            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al duplicar tarea: {ex.Message}";
        }
    }

    private void OnCustomizeEditModel(GridCustomizeEditModelEventArgs e)
    {
        if (!e.IsNew)
            return;

        var nuevaTarea = (Tarea)e.EditModel;
        nuevaTarea.IdTarea = 0;

    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (Tarea)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/tareas/{dataItem.IdTarea}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar tarea: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }
}

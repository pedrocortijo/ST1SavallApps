@page "/modelos/poblaciones"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Gestión de Poblaciones</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Poblaciones (Códigos Postales)</h2>
            <p class="text-muted mb-0">Administración de códigos postales y poblaciones de Sage50</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (poblaciones == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando poblaciones...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@poblaciones"
                        KeyFieldName="Key"
                        EditMode="GridEditMode.PopupEditForm"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormCssClass="crud-popup"
                        PopupEditFormHeaderText="Formulario de Población"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        SearchBoxNullText="Buscar población...">
                    <Columns>
                        <DxGridCommandColumn Width="80px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nueva Población">
                                    <i class="oi oi-plus me-1"></i> Nueva
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var item = (CodPosSage50)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(item)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(item)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="Codigo" Caption="Código Postal" Width="120px" />
                        <DxGridDataColumn FieldName="Linea" Caption="Línea" Width="80px" />
                        <DxGridDataColumn FieldName="Cpostalm" Caption="Cód. Municipio" Width="130px" Visible="false" />
                        <DxGridDataColumn FieldName="Poblacion" Caption="Población" />
                        <DxGridDataColumn FieldName="Provincia" Caption="Provincia" />
                        <DxGridDataColumn FieldName="Lati" Caption="Latitud" Width="120px" Visible="false" />
                        <DxGridDataColumn FieldName="Longi" Caption="Longitud" Width="120px" Visible="false" />
                        <DxGridDataColumn FieldName="Vista" Caption="Visible" Width="80px" />
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var item = (CodPosSage50)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3">
                            <DxFormLayoutItem Caption="Código Postal" ColSpanMd="6" Enabled="@(EditFormContext.DataItem == null)">
                                <DxTextBox @bind-Text="@item.Codigo" MaxLength="10" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Línea" ColSpanMd="6" Enabled="@(EditFormContext.DataItem == null)">
                                <DxTextBox @bind-Text="@item.Linea" MaxLength="5" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Población" ColSpanMd="12">
                                <DxTextBox @bind-Text="@item.Poblacion" MaxLength="30" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Provincia" ColSpanMd="12">
                                <DxTextBox @bind-Text="@item.Provincia" MaxLength="30" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Latitud" ColSpanMd="6">
                                <DxTextBox @bind-Text="@item.Lati" MaxLength="30" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Longitud" ColSpanMd="6">
                                <DxTextBox @bind-Text="@item.Longi" MaxLength="30" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Cód. Municipio" ColSpanMd="6">
                                <DxTextBox @bind-Text="@item.Cpostalm" MaxLength="5" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Visible" ColSpanMd="6">
                                <DxCheckBox @bind-Checked="@item.Vista" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="7" BeginRow="true" CssClass="d-flex align-items-end pb-1">
                                <button type="button" class="btn btn-outline-primary btn-sm w-100" @onclick="async () => await ObtenerUbicacionActualAsync(item)" style="height: 38px;">
                                    <i class="oi oi-map-marker me-1"></i> Obtener coordenadas del dispositivo
                                </button>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="5" CssClass="d-flex align-items-end pb-1">
                                <button type="button" class="btn btn-outline-success btn-sm w-100" @onclick="async () => await VerEnMapaAsync(item)" style="height: 38px;" title="Ver en Google Maps">
                                    <i class="oi oi-eye me-1"></i> Ver en Maps
                                </button>
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<CodPosSage50>? poblaciones;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            poblaciones = await Http.GetFromJsonAsync<List<CodPosSage50>>("api/codpossage50");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar poblaciones: {ex.Message}";
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (CodPosSage50)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/codpossage50", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear población: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/codpossage50/{editModel.Codigo}/{editModel.Linea}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar población: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (CodPosSage50)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/codpossage50/{dataItem.Codigo}/{dataItem.Linea}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar población: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }

    private Task VerEnMapaAsync(CodPosSage50 item)
    {
        var title = item.Poblacion ?? "Población";
        var query = ST1Savall.MapHelper.BuildNormalizedQuery(item.Poblacion, null, item.Provincia, item.Codigo);
        if (string.IsNullOrWhiteSpace(query))
        {
            errorMessage = "Introduzca una población, provincia o código postal primero para verla en el mapa.";
            return Task.CompletedTask;
        }

        var latParam = TryParseCoordinate(item.Lati, out var lat) ? $"&lat={lat.ToString(System.Globalization.CultureInfo.InvariantCulture)}" : string.Empty;
        var lonParam = TryParseCoordinate(item.Longi, out var lon) ? $"&lon={lon.ToString(System.Globalization.CultureInfo.InvariantCulture)}" : string.Empty;
        var mapsUrl = $"/modelos/contenedores/mapa?address={Uri.EscapeDataString(query)}&title={Uri.EscapeDataString(title)}{latParam}{lonParam}&backUrl={Uri.EscapeDataString("/modelos/poblaciones")}";
        NavigationManager.NavigateTo(mapsUrl);
        return Task.CompletedTask;
    }

    private static bool TryParseCoordinate(string? value, out double coordinate)
    {
        return double.TryParse(value?.Trim(), System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out coordinate)
            || double.TryParse(value?.Trim(), System.Globalization.NumberStyles.Float, new System.Globalization.CultureInfo("es-ES"), out coordinate);
    }

    private async Task ObtenerUbicacionActualAsync(CodPosSage50 item)
    {
        try
        {
            var result = await JSRuntime.InvokeAsync<DeviceCoordinates>("eval", @"
                new Promise((resolve, reject) => {
                    if (!navigator.geolocation) {
                        reject('Geolocalización no soportada');
                        return;
                    }
                    navigator.geolocation.getCurrentPosition(
                        pos => resolve({ latitud: pos.coords.latitude, longitud: pos.coords.longitude }),
                        err => reject('Error al obtener ubicación: ' + err.message),
                        { enableHighAccuracy: true, timeout: 5000, maximumAge: 0 }
                    );
                })");

            item.Lati = result.Latitud.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
            item.Longi = result.Longitud.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
            errorMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo obtener la ubicación: {ex.Message}";
        }
    }

    private async Task ObtenerCoordenadasAsync(CodPosSage50 item)
    {
        if (string.IsNullOrWhiteSpace(item.Codigo) && string.IsNullOrWhiteSpace(item.Poblacion))
        {
            errorMessage = "Debe introducir el código postal o la población para buscar coordenadas.";
            return;
        }

        try
        {
            var result = await JSRuntime.InvokeAsync<GeocodeResult>("eval", $@"
                new Promise(async (resolve, reject) => {{
                    try {{
                        const codigo = '{Uri.EscapeDataString(item.Codigo ?? "")}';
                        const poblacion = '{Uri.EscapeDataString(item.Poblacion ?? "")}';
                        
                        // Intentar búsqueda estructurada primero
                        let url = `https://nominatim.openstreetmap.org/search?format=json&postalcode=${{codigo}}&city=${{poblacion}}&country=Spain&limit=1`;
                        let res = await fetch(url);
                        let data = await res.json();
                        
                        if (data && data.length > 0) {{
                            resolve({{ latitud: data[0].lat, longitud: data[0].lon }});
                            return;
                        }}
                        
                        // Si falla, intentar búsqueda libre
                        url = `https://nominatim.openstreetmap.org/search?format=json&q=${{codigo}}+${{poblacion}}+Spain&limit=1`;
                        res = await fetch(url);
                        data = await res.json();
                        
                        if (data && data.length > 0) {{
                            resolve({{ latitud: data[0].lat, longitud: data[0].lon }});
                        }} else {{
                            reject('No se encontraron coordenadas para esta población y código postal.');
                        }}
                    }} catch (e) {{
                        reject('Error en la petición: ' + e.message);
                    }}
                }})
            ");

            if (result != null)
            {
                item.Lati = result.Latitud;
                item.Longi = result.Longitud;
                errorMessage = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron obtener las coordenadas: {ex.Message}";
        }
    }

    private class GeocodeResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("latitud")]
        public string Latitud { get; set; } = string.Empty;
        [System.Text.Json.Serialization.JsonPropertyName("longitud")]
        public string Longitud { get; set; } = string.Empty;
    }

    private class DeviceCoordinates
    {
        [System.Text.Json.Serialization.JsonPropertyName("latitud")]
        public double Latitud { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("longitud")]
        public double Longitud { get; set; }
    }
}

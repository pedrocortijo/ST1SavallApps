@page "/modelos/solicitudes/edit"
@page "/modelos/solicitudes/edit/{Id:int}"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>@(Id.HasValue ? "Editar Solicitud" : "Nueva Solicitud")</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">@(Id.HasValue ? "Editar Solicitud" : "Nueva Solicitud")</h2>
            <p class="text-muted mb-0">Complete los datos de la solicitud de trabajo</p>
        </div>
        <div class="d-flex gap-2">
            <NavLink href="/servicios/planificacion" class="btn btn-outline-primary btn-sm">
                <i class="oi oi-calendar me-1"></i> Planificación
            </NavLink>
            <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
                <i class="oi oi-arrow-left me-1"></i> Volver a Solicitudes
            </button>
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (loading)
    {
        <div class="p-5 text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2 text-muted mb-0">Cargando datos...</p>
        </div>
    }
    else if (solicitud != null)
    {
        <div class="card shadow-sm border-0" style="border-radius: 12px;">
            <div class="card-body p-4">
                <DxFormLayout CssClass="w-100" CaptionPosition="CaptionPosition.Vertical">
                    <!-- Grupo: Obra / Cliente -->
                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary border-bottom pb-2 mb-3">
                        Obra / Cliente
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Nº Solicitud" ColSpanMd="2" BeginRow="true" Enabled="false">
                        <DxSpinEdit @bind-Value="@solicitud.IdSolicitud" ShowSpinButtons="false" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha Solicitud" ColSpanMd="2">
                        <DxDateEdit @bind-Date="@solicitud.FechaSolicitud" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Obra" ColSpanMd="2">
                        <DxComboBox Data="@obras"
                                    TextFieldName="Codigo"
                                    ValueFieldName="IdObra"
                                    Value="@solicitud.IdCliente"
                                    ValueChanged="@((int val) => OnObraChanged(val))" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="12" BeginRow="true">
                        <Template>
                            <div class="p-3 rounded border mb-2" style="background-color: rgba(128, 128, 128, 0.05);">
                                <div class="row g-3">
                                    <div class="col-md-6 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Nombre Obra:</span>
                                        <span>@(solicitud.NombreObra ?? "-")</span>
                                    </div>
                                    <div class="col-md-6 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Cliente:</span>
                                        <span>@(solicitud.NombreCliente ?? "-")</span>
                                    </div>
                                    <div class="col-md-8 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Dirección Obra:</span>
                                        <span>@(solicitud.DireccionCliente ?? "-")</span>
                                    </div>
                                    <div class="col-md-4 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Población:</span>
                                        <span>@(solicitud.PoblacionCliente ?? "-")</span>
                                    </div>
                                    <div class="col-md-4 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Encargado:</span>
                                        <span>@(solicitud.Encargado ?? "-")</span>
                                    </div>
                                    <div class="col-md-4 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Teléfono:</span>
                                        <span>@(solicitud.TelefonoCliente ?? "-")</span>
                                    </div>
                                    <div class="col-md-4 col-12 d-flex align-items-baseline gap-2">
                                        <span class="fw-bold text-nowrap" style="opacity: 0.75; font-size: 0.85rem;">Móvil:</span>
                                        <span>@(solicitud.Movil ?? "-")</span>
                                    </div>
                                </div>
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                    <!-- Grupo 1: Datos Generales -->
                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                        Datos de la Tarea
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha Tarea" ColSpanMd="2">
                        <DxDateEdit @bind-Date="@solicitud.FechaTarea" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Usuario" ColSpanMd="4">
                        <DxComboBox Data="@usuariosSage"
                                    TextFieldName="Nombre"
                                    ValueFieldName="Codigo"
                                    @bind-Value="@solicitud.IdOperario"
                                    ClearButtonVisible="true" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
                        <DxComboBox Data="@estadosList"
                                    TextFieldName="Descripcion"
                                    ValueFieldName="IdEstado"
                                    @bind-Value="@solicitud.Estado" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Conductor" ColSpanMd="3" BeginRow="true">
                        <DxComboBox Data="@operarios"
                                    TextFieldName="Nombre"
                                    ValueFieldName="IdOperario"
                                    @bind-Value="@solicitud.IdConductor"
                                    ClearButtonVisible="true" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Tipo de Tarea" ColSpanMd="3" >
                        <DxComboBox Data="@tareasList"
                                    TextFieldName="NombreTarea"
                                    ValueFieldName="IdTarea"
                                    Value="@solicitud.IdTipoTarea"
                                    ValueChanged="@((int val) => OnTareaChanged(val))" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Hora" ColSpanMd="3">
                        <DxTextBox @bind-Value="@solicitud.HoraLlegada" />
                    </DxFormLayoutItem>


                    <DxFormLayoutItem Caption="Prioridad" ColSpanMd="3">
                        <DxComboBox Data="@prioridadesList"
                                    TextFieldName="Name"
                                    ValueFieldName="Id"
                                    @bind-Value="@solicitud.Prioridad" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                        Planificación del servicio
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Inicio planificado" ColSpanMd="3" BeginRow="true">
                        <DxDateEdit @bind-Date="@solicitud.FechaHoraInicioPlanificada"
                                    TimeSectionVisible="true"
                                    DisplayFormat="dd/MM/yyyy HH:mm" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fin planificado" ColSpanMd="3" Enabled="false">
                        <DxDateEdit @bind-Date="@solicitud.FechaHoraFinPlanificada"
                                    TimeSectionVisible="true"
                                    DisplayFormat="dd/MM/yyyy HH:mm" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Duración total (minutos)" ColSpanMd="2">
                        <DxSpinEdit Value="@solicitud.DuracionPlanificadaMinutos"
                                    ValueChanged="@((int? value) => OnDuracionTotalChanged(value))"
                                    MinValue="1" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Viaje (minutos)" ColSpanMd="1">
                        <DxSpinEdit @bind-Value="@solicitud.DuracionViajeMinutos" MinValue="0" Enabled="false" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Operación (minutos)" ColSpanMd="1">
                        <DxSpinEdit Value="@solicitud.DuracionOperacionMinutos"
                                    ValueChanged="@((int? value) => OnDuracionOperacionChanged(value))"
                                    MinValue="0" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="2" CssClass="d-flex align-items-end pb-1">
                        <button type="button" class="btn btn-outline-primary btn-sm w-100" @onclick="ProponerSiguienteHuecoAsync">
                            <i class="oi oi-clock me-1"></i> Siguiente hora libre
                        </button>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Planta origen" ColSpanMd="4" BeginRow="true">
                        <DxComboBox Data="@plantas" TextFieldName="Nombre" ValueFieldName="IdPlanta" @bind-Value="@solicitud.IdPlantaOrigen" ClearButtonVisible="true" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Planta descarga" ColSpanMd="4">
                        <DxComboBox Data="@plantas" TextFieldName="Nombre" ValueFieldName="IdPlanta" @bind-Value="@solicitud.IdPlantaDescarga" ClearButtonVisible="true" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Central de regreso" ColSpanMd="4">
                        <DxComboBox Data="@plantas" TextFieldName="Nombre" ValueFieldName="IdPlanta" @bind-Value="@solicitud.IdPlantaRegreso" ClearButtonVisible="true" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="3" BeginRow="true">
                        <button type="button"
                                class="btn btn-outline-success btn-sm w-100"
                                disabled="@calculandoRuta"
                                @onclick="() => CalcularRutaAsync(true)">
                            @if (calculandoRuta)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="oi oi-map-marker me-1"></i>
                            }
                            Calcular ruta
                        </button>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="3">
                        <DxCheckBox @bind-Checked="@solicitud.DuracionModificadaManualmente" LabelPosition="LabelPosition.Right">
                            Duración total manual
                        </DxCheckBox>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="6">
                        @if (solicitud.DistanciaTotalMetros.HasValue)
                        {
                            <div class="small text-muted pt-2">
                                <strong>@FormatKilometros(solicitud.DistanciaTotalMetros)</strong>
                                · Origen→Obra: @solicitud.MinutosOrigenObra min
                                · Obra→Descarga: @solicitud.MinutosObraDescarga min
                                · Descarga→Regreso: @solicitud.MinutosDescargaRegreso min
                                <span class="ms-2" translate="no" style="font-size: 12px; font-weight: 400; color: #5e5e5e; white-space: nowrap;">Mapbox</span>
                            </div>
                        }
                    </DxFormLayoutItem>
                    @if (!string.IsNullOrWhiteSpace(planificacionMessage))
                    {
                        <DxFormLayoutItem ColSpanMd="12" BeginRow="true">
                            <div class="alert alert-info py-2 mb-0">@planificacionMessage</div>
                        </DxFormLayoutItem>
                    }

                    <DxFormLayoutItem Caption="Observaciones para el conductor" ColSpanMd="12" BeginRow="true">
                        <DxTextBox @bind-Text="@solicitud.Observaciones" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Comentarios para oficina" ColSpanMd="12" BeginRow="true">
                        <DxTextBox @bind-Text="@comentariosOficina" />
                    </DxFormLayoutItem>

                    <!-- Grupo 3: Contenedor y Ubicación -->
                    <DxFormLayoutItem ColSpanMd="12" BeginRow="true">
                        <Template>
                            <div class="row g-4">
                                <!-- Columna Izquierda: Contenedor -->
                                <div class="col-md-6 border-end pe-md-4">
                                    <h6 class="fw-bold text-primary mb-3 pb-2 border-bottom">Contenedores</h6>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-muted small mb-1">Datos entrega</label>
                                        <DxComboBox Data="@contenedoresEntrega"
                                                    Enabled="@IsEntregaEnabled"
                                                    TData="Contenedor"
                                                    TValue="string"
                                                    TextFieldName="NumSerie"
                                                    ValueFieldName="NumSerie"
                                                    @bind-Value="@solicitud.CodigoEntrega"
                                                    ClearButtonVisible="true"
                                                    SearchMode="ListSearchMode.AutoSearch"
                                                    SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                    AllowUserInput="false">
                                            <Columns>
                                                <DxListEditorColumn FieldName="NumSerie" Caption="Nº Serie" />
                                                <DxListEditorColumn FieldName="Tipo.Descripcion" Caption="Tipo" />
                                                <DxListEditorColumn FieldName="EstadoFisico" Caption="Estado" />
                                            </Columns>
                                        </DxComboBox>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-muted small mb-1">Datos recogida</label>
                                        <DxComboBox Data="@contenedoresRecogida"
                                                    Enabled="@IsRecogidaEnabled"
                                                    TData="Contenedor"
                                                    TValue="string"
                                                    TextFieldName="NumSerie"
                                                    ValueFieldName="NumSerie"
                                                    @bind-Value="@solicitud.CodigoRecogida"
                                                    ClearButtonVisible="true"
                                                    SearchMode="ListSearchMode.AutoSearch"
                                                    SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                    AllowUserInput="false">
                                            <Columns>
                                                <DxListEditorColumn FieldName="NumSerie" Caption="Nº Serie" />
                                                <DxListEditorColumn FieldName="Tipo.Descripcion" Caption="Tipo" />
                                                <DxListEditorColumn FieldName="EstadoFisico" Caption="Estado" />
                                            </Columns>
                                        </DxComboBox>
                                    </div>
                                </div>

                                <!-- Columna Derecha: Localización GPS -->
                                <div class="col-md-6 ps-md-4">
                                    <h6 class="fw-bold text-primary mb-3 pb-2 border-bottom">Localización GPS</h6>
                                    <div class="row g-2">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold text-muted small mb-1">Latitud</label>
                                            <DxSpinEdit @bind-Value="@solicitud.Latitud" DecimalPlaces="6" ShowSpinButtons="false" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold text-muted small mb-1">Longitud</label>
                                            <DxSpinEdit @bind-Value="@solicitud.Longitud" DecimalPlaces="6" ShowSpinButtons="false" />
                                        </div>
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <button type="button" class="btn btn-outline-primary btn-sm w-100" @onclick="ObtenerUbicacionActualAsync" style="height: 38px;">
                                                <i class="oi oi-map-marker me-1"></i> Ubicación Actual
                                            </button>
                                        </div>
                                        <div class="col-6">
                                            <button type="button" class="btn btn-outline-success btn-sm w-100" @onclick="VerCoordenadasEnMapa" style="height: 38px;" title="Ver coordenadas en Google Maps">
                                                <i class="oi oi-eye me-1"></i> Ver en Maps
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                    <!-- Grupo 4: Aplazamiento de tarea -->
                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                        Aplazamiento de tarea
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha Próxima Prevista" ColSpanMd="2" BeginRow="true">
                        <DxDateEdit @bind-Date="@solicitud.FechaPrevista" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Motivo del aplazamiento" ColSpanMd="10">
                        <DxSpinEdit @bind-Value="@solicitud.MotivoReprogramacion" ShowSpinButtons="false" />
                    </DxFormLayoutItem>

                    <!-- Grupo 5: Ocupación de Vía Pública (OVP) -->
                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                        Ocupación de Vía Pública (OVP)
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="4" BeginRow="true" CssClass="d-flex align-items-center">
                        <DxCheckBox @bind-Checked="@solicitud.RequiereOVP" LabelPosition="LabelPosition.Right">Requiere Licencia OVP</DxCheckBox>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Nº Licencia" ColSpanMd="8">
                        <DxTextBox @bind-Text="@solicitud.NumLicenciaOVP" Enabled="@solicitud.RequiereOVP" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha Inicio OVP" ColSpanMd="6" BeginRow="true">
                        <DxDateEdit @bind-Date="@solicitud.FechaInicioOVP" Enabled="@solicitud.RequiereOVP" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha Fin OVP" ColSpanMd="6">
                        <DxDateEdit @bind-Date="@solicitud.FechaFinOVP" Enabled="@solicitud.RequiereOVP" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanMd="12" BeginRow="true" CssClass="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <button class="btn btn-outline-secondary btn-sm px-4" @onclick="GoBack">Cancelar</button>
                        <button class="btn btn-primary btn-sm px-4" @onclick="SaveAsync">Guardar</button>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    [SupplyParameterFromQuery]
    public int? ObraId { get; set; }

    [SupplyParameterFromQuery]
    public int? TareaId { get; set; }

    [SupplyParameterFromQuery]
    public string? ContenedorCodigo { get; set; }

    private Solicitud? solicitud;
    private List<Operario>? operarios;
    private List<UsuarioComunSage50>? usuariosSage;
    private List<EstadoSolicitud>? estadosList;
    private List<Obra>? obras;
    private List<Contenedor>? contenedoresList;
    private List<Planta>? plantas;
    private bool loading = true;
    private string? errorMessage;
    private string? comentariosOficina;
    private string? planificacionMessage;
    private bool calculandoRuta;

    private class KeyName
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    private List<Tarea>? tareasList;

    private List<KeyName> prioridadesList = new()
    {
        new() { Id = 1, Name = "Alta" },
        new() { Id = 2, Name = "Media" },
        new() { Id = 3, Name = "Baja" }
    };

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            loading = true;
            operarios = await Http.GetFromJsonAsync<List<Operario>>("api/operarios");
            usuariosSage = await Http.GetFromJsonAsync<List<UsuarioComunSage50>>("api/UsuariosComunSage50");
            estadosList = await Http.GetFromJsonAsync<List<EstadoSolicitud>>("api/estadosSolicitud");
            obras = await Http.GetFromJsonAsync<List<Obra>>("api/obras");
            tareasList = await Http.GetFromJsonAsync<List<Tarea>>("api/tareas");
            plantas = await Http.GetFromJsonAsync<List<Planta>>("api/plantas");

            if (Id.HasValue)
            {
                solicitud = await Http.GetFromJsonAsync<Solicitud>($"api/solicitudes/{Id.Value}");
            }
            else
            {
                solicitud = new Solicitud
                {
                    FechaSolicitud = DateTime.Today,
                    //FechaInicial = DateTime.Today,
                    //FechaTarea = DateTime.Today,
                    Estado = 1, // Introducido por defecto
                    IdConductor = null, // Sin asignar por defecto
                    DuracionPlanificadaMinutos = 60,
                    DuracionOperacionMinutos = 30
                };

                if (ObraId.HasValue)
                {
                    solicitud.IdCliente = ObraId.Value;
                    var obra = obras?.FirstOrDefault(o => o.IdObra == ObraId.Value);
                    if (obra != null)
                    {
                        solicitud.NombreObra = obra.Descripcion;
                        solicitud.NombreCliente = obra.NombreCliente;
                        solicitud.DireccionCliente = obra.Ubicacion;
                        solicitud.PoblacionCliente = obra.Poblacion;
                        solicitud.TelefonoCliente = obra.Telefono;
                        solicitud.Encargado = obra.Encargado;
                        solicitud.Movil = obra.Movil;
                    }
                }

                if (TareaId.HasValue)
                {
                    solicitud.IdTipoTarea = TareaId.Value;
                }

                if (!string.IsNullOrEmpty(ContenedorCodigo))
                {
                    solicitud.CodigoRecogida = ContenedorCodigo;
                }
            }

            var allContenedores = await Http.GetFromJsonAsync<List<Contenedor>>("api/contenedores");
            if (allContenedores != null)
            {
                contenedoresList = allContenedores;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void OnObraChanged(int val)
    {
        if (solicitud == null) return;
        solicitud.IdCliente = val;
        var obra = obras?.FirstOrDefault(o => o.IdObra == val);
        if (obra != null)
        {
            solicitud.NombreObra = obra.Descripcion;
            solicitud.NombreCliente = obra.NombreCliente;
            solicitud.DireccionCliente = obra.Ubicacion;
            solicitud.PoblacionCliente = obra.Poblacion;
            solicitud.TelefonoCliente = obra.Telefono;
            solicitud.Encargado = obra.Encargado;
            solicitud.Movil = obra.Movil;
        }
    }

    private async Task SaveAsync()
    {
        if (solicitud == null) return;
        try
        {
            SyncCoordinates();
            if (solicitud.Latitud.HasValue && solicitud.Longitud.HasValue)
            {
                solicitud.LatitudObra = solicitud.Latitud;
                solicitud.LongitudObra = solicitud.Longitud;
            }

            if (TieneDatosRutaCompletos() && !await CalcularRutaAsync(false))
                return;

            solicitud.FechaActualizacion = DateTime.Now;
            await SetupHeadersAsync();
            HttpResponseMessage response;
            if (Id.HasValue)
            {
                response = await Http.PutAsJsonAsync($"api/solicitudes/{solicitud.IdSolicitud}", solicitud);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/solicitudes", solicitud);
            }

            if (response.IsSuccessStatusCode)
            {
                GoBack();
            }
            else
            {
                var apiError = await response.Content.ReadFromJsonAsync<ApiError>();
                errorMessage = apiError?.Message ?? $"Error al guardar la solicitud: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ocurrió un error al guardar: {ex.Message}";
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/modelos/solicitudes");
    }

    private async Task ProponerSiguienteHuecoAsync()
    {
        if (solicitud?.IdConductor == null)
        {
            planificacionMessage = "Seleccione primero un conductor.";
            return;
        }

        var duracion = solicitud.DuracionPlanificadaMinutos.GetValueOrDefault(60);
        var desde = solicitud.FechaHoraInicioPlanificada
                    ?? solicitud.FechaTarea?.Date.AddHours(8)
                    ?? DateTime.Today.AddHours(8);
        var url = $"api/solicitudes/siguiente-hueco?idConductor={solicitud.IdConductor.Value}&fecha={Uri.EscapeDataString(desde.ToString("O"))}&duracionMinutos={duracion}&excluirSolicitudId={solicitud.IdSolicitud}";
        var hueco = await Http.GetFromJsonAsync<PlanificacionHueco>(url);
        if (hueco?.Disponible == true)
        {
            solicitud.FechaHoraInicioPlanificada = hueco.Inicio;
            solicitud.FechaHoraFinPlanificada = hueco.Fin;
            solicitud.FechaTarea = hueco.Inicio?.Date;
            planificacionMessage = $"Hueco propuesto: {hueco.Inicio:dd/MM/yyyy HH:mm}–{hueco.Fin:HH:mm}.";
        }
        else
        {
            planificacionMessage = hueco?.Mensaje ?? "No se encontró disponibilidad.";
        }
    }

    private async Task<bool> CalcularRutaAsync(bool mostrarMensaje)
    {
        if (solicitud == null) return false;

        SyncCoordinates();
        if (!TieneDatosRutaCompletos())
        {
            errorMessage = "Seleccione las tres plantas e indique las coordenadas de la obra.";
            return false;
        }

        try
        {
            calculandoRuta = true;
            errorMessage = null;
            await SetupHeadersAsync();
            var response = await Http.PostAsJsonAsync("api/solicitudes/calcular-ruta", solicitud);
            if (!response.IsSuccessStatusCode)
            {
                var apiError = await response.Content.ReadFromJsonAsync<ApiError>();
                errorMessage = apiError?.Message ?? $"No se pudo calcular la ruta: {response.ReasonPhrase}";
                return false;
            }

            var resultado = await response.Content.ReadFromJsonAsync<CalculoRutaSolicitudResultado>();
            if (resultado?.Calculado != true || resultado.Solicitud == null)
            {
                errorMessage = resultado?.Mensaje ?? "Mapbox no devolvió un cálculo válido.";
                return false;
            }

            solicitud = resultado.Solicitud;
            if (mostrarMensaje)
            {
                var origenDatos = resultado.TramosDesdeProveedor > 0
                    ? $"{resultado.TramosDesdeProveedor} tramo(s) consultados a Mapbox"
                    : "todos los tramos recuperados de caché";
                planificacionMessage = $"{resultado.Mensaje} ({origenDatos}).";
            }

            return true;
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo calcular la ruta: {ex.Message}";
            return false;
        }
        finally
        {
            calculandoRuta = false;
        }
    }

    private bool TieneDatosRutaCompletos() =>
        solicitud?.IdPlantaOrigen.HasValue == true &&
        solicitud.IdPlantaDescarga.HasValue &&
        solicitud.IdPlantaRegreso.HasValue &&
        solicitud.Latitud.HasValue &&
        solicitud.Longitud.HasValue;

    private void OnDuracionTotalChanged(int? value)
    {
        if (solicitud == null) return;
        solicitud.DuracionPlanificadaMinutos = value;
        solicitud.DuracionModificadaManualmente = true;
        ActualizarFinPlanificado();
    }

    private void OnDuracionOperacionChanged(int? value)
    {
        if (solicitud == null) return;
        solicitud.DuracionOperacionMinutos = value;
        if (!solicitud.DuracionModificadaManualmente)
            solicitud.DuracionPlanificadaMinutos = solicitud.DuracionViajeMinutos.GetValueOrDefault() + value.GetValueOrDefault();
        ActualizarFinPlanificado();
    }

    private void ActualizarFinPlanificado()
    {
        if (solicitud?.FechaHoraInicioPlanificada.HasValue == true && solicitud.DuracionPlanificadaMinutos > 0)
            solicitud.FechaHoraFinPlanificada = solicitud.FechaHoraInicioPlanificada.Value.AddMinutes(solicitud.DuracionPlanificadaMinutos.Value);
    }

    private static string FormatKilometros(int? metros) => $"{metros.GetValueOrDefault() / 1000d:0.0} km";

    private sealed class ApiError
    {
        public string? Message { get; set; }
    }



    private Task VerCoordenadasEnMapa()
    {
        if (solicitud == null) return Task.CompletedTask;

        double? lat = null;
        double? lon = null;
        if (solicitud.Latitud.HasValue && solicitud.Longitud.HasValue)
        {
            lat = (double)solicitud.Latitud.Value;
            lon = (double)solicitud.Longitud.Value;
        }
        else if (!string.IsNullOrWhiteSpace(solicitud.CoordenadasGPS))
        {
            var parts = solicitud.CoordenadasGPS.Split(',');
            if (parts.Length == 2 && 
                double.TryParse(parts[0].Trim(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedLat) && 
                double.TryParse(parts[1].Trim(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedLon))
            {
                lat = parsedLat;
                lon = parsedLon;
            }
        }

        var address = ST1Savall.MapHelper.BuildNormalizedQuery(solicitud.DireccionCliente, solicitud.PoblacionCliente, null, null);
        if (string.IsNullOrEmpty(address))
        {
            address = "Ubicación de Solicitud";
        }

        var backUrl = "/modelos/solicitudes";
        if (Id.HasValue)
        {
            backUrl = $"/modelos/solicitudes/edit/{Id.Value}";
        }

        // Obtener la serie del contenedor y su descripción si está asignado
        var serie = solicitud.CodigoEntrega ?? solicitud.CodigoRecogida ?? string.Empty;
        var obra = solicitud.NombreObra ?? "Ubicación de Solicitud";
        var tipo = "Ubicación de Solicitud";

        if (!string.IsNullOrEmpty(serie))
        {
            var cont = contenedoresList?.FirstOrDefault(c => c.NumSerie == serie);
            if (cont != null)
            {
                tipo = cont.Tipo?.Descripcion ?? "Contenedor";
            }
        }

        var latParam = lat.HasValue ? $"&lat={lat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}" : "";
        var lonParam = lon.HasValue ? $"&lon={lon.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}" : "";
        var serieParam = !string.IsNullOrEmpty(serie) ? $"&serie={Uri.EscapeDataString(serie)}" : "";
        var obraParam = $"&obra={Uri.EscapeDataString(obra)}";

        var mapsUrl = $"/modelos/contenedores/mapa?address={Uri.EscapeDataString(address)}&title={Uri.EscapeDataString(tipo)}{serieParam}{obraParam}{latParam}{lonParam}&backUrl={Uri.EscapeDataString(backUrl)}";
        NavigationManager.NavigateTo(mapsUrl);
        return Task.CompletedTask;
    }

    private void OnCoordenadasGPSTextChanged(string val)
    {
        if (solicitud == null) return;
        solicitud.CoordenadasGPS = val;

        if (!string.IsNullOrWhiteSpace(val))
        {
            var cleanCoords = val.Replace(" ", "").Replace(";", ",");
            var parts = cleanCoords.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2)
            {
                if (decimal.TryParse(parts[0].Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal lat) &&
                    decimal.TryParse(parts[1].Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal lon))
                {
                    solicitud.Latitud = lat;
                    solicitud.Longitud = lon;
                }
            }
        }
    }

    private void SyncCoordinates()
    {
        if (solicitud == null) return;

        // Prioritize Latitud and Longitud if they have values to keep CoordenadasGPS string updated
        if (solicitud.Latitud.HasValue && solicitud.Longitud.HasValue)
        {
            solicitud.CoordenadasGPS = $"{solicitud.Latitud.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)},{solicitud.Longitud.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)}";
        }
        // If they are null/not set but CoordenadasGPS has a value, parse it to populate Latitud and Longitud
        else if (!string.IsNullOrWhiteSpace(solicitud.CoordenadasGPS))
        {
            var cleanCoords = solicitud.CoordenadasGPS.Replace(" ", "").Replace(";", ",");
            var parts = cleanCoords.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2)
            {
                if (decimal.TryParse(parts[0].Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal lat) &&
                    decimal.TryParse(parts[1].Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal lon))
                {
                    solicitud.Latitud = lat;
                    solicitud.Longitud = lon;
                }
            }
        }
    }

    private async Task ObtenerUbicacionActualAsync()
    {
        try
        {
            var posicion = await JSRuntime.InvokeAsync<GpsPosition>("eval", @"
                new Promise((resolve, reject) => {
                    if (!navigator.geolocation) {
                        reject('Geolocalización no soportada');
                    } else {
                        navigator.geolocation.getCurrentPosition(
                            (pos) => resolve({ latitud: pos.coords.latitude, longitud: pos.coords.longitude }),
                            (err) => reject('Error al obtener ubicación: ' + err.message),
                            { enableHighAccuracy: true, timeout: 5000, maximumAge: 0 }
                        );
                    }
                })
            ");

            if (posicion != null && solicitud != null)
            {
                solicitud.Latitud = (decimal)posicion.Latitud;
                solicitud.Longitud = (decimal)posicion.Longitud;
                SyncCoordinates();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo obtener la ubicación: {ex.Message}";
        }
    }

    private List<Contenedor> contenedoresEntrega =>
        contenedoresList?
            .Where(c => c.EstadoFisico != null && (c.EstadoFisico.Equals("Disponible", StringComparison.OrdinalIgnoreCase)
                     || (!string.IsNullOrEmpty(solicitud?.CodigoEntrega) && c.NumSerie == solicitud.CodigoEntrega)))
            .ToList() ?? new List<Contenedor>();

    private List<Contenedor> contenedoresRecogida =>
        contenedoresList?
            .Where(c => c.EstadoFisico != null && (c.EstadoFisico.Equals("Entregado", StringComparison.OrdinalIgnoreCase)
                     || (!string.IsNullOrEmpty(solicitud?.CodigoRecogida) && c.NumSerie == solicitud.CodigoRecogida)))
            .ToList() ?? new List<Contenedor>();

    private bool IsEntregaEnabled =>
        solicitud != null && (solicitud.IdTipoTarea == 1 || solicitud.IdTipoTarea == 8);

    private bool IsRecogidaEnabled =>
        solicitud != null && (solicitud.IdTipoTarea == 7 || solicitud.IdTipoTarea == 8);

    private void OnTareaChanged(int val)
    {
        if (solicitud == null) return;
        solicitud.IdTipoTarea = val;
        
        if (val != 1 && val != 8)
        {
            solicitud.CodigoEntrega = null;
        }
        
        if (val != 7 && val != 8)
        {
            solicitud.CodigoRecogida = null;
        }
    }

    private class GpsPosition
    {
        [System.Text.Json.Serialization.JsonPropertyName("latitud")]
        public double Latitud { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("longitud")]
        public double Longitud { get; set; }
    }

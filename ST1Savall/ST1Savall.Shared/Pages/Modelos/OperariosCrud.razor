@page "/modelos/operarios"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Operarios</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Operarios</h2>
            <p class="text-muted mb-0">Gestión de operarios, información de contacto, asignación de cargos y permisos</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (operarios == null || cargos == null || plantas == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando operarios, cargos y plantas...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@operarios"
                        KeyFieldName="IdOperario"
                        EditMode="GridEditMode.PopupEditForm"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormHeaderText="Formulario - Operario"
                        PopupEditFormCssClass="crud-popup"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true">
                    <Columns>
                        <DxGridCommandColumn Width="80px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nuevo Operario">
                                    <i class="oi oi-plus me-1"></i> Nuevo
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var oper = (Operario)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(oper)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(oper)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="IdOperario" Caption="Código" ReadOnly="true" Width="80px" Visible="false"/>
                        <DxGridDataColumn FieldName="Nombre" Caption="Nombre" Width="130px" TextAlignment="GridTextAlignment.Left" />
                        <DxGridDataColumn FieldName="Telefono" Caption="Teléfono" Width="100px" TextAlignment="GridTextAlignment.Left" />
                        <DxGridDataColumn FieldName="IdCargo" Caption="Cargo Asignado" Width="150px" TextAlignment="GridTextAlignment.Left">
                            <CellDisplayTemplate>
                                @{
                                    var oper = (Operario)context.DataItem;
                                    if (oper.IdCargo.HasValue)
                                    {
                                        var c = cargos.FirstOrDefault(x => x.IdCargo == oper.IdCargo.Value);
                                        @c?.Descripcion
                                    }
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="IdPlanta" Caption="Planta Asignada" TextAlignment="GridTextAlignment.Left">
                            <CellDisplayTemplate>
                                @{
                                    var oper = (Operario)context.DataItem;
                                    if (oper.IdPlanta.HasValue && plantas != null)
                                    {
                                        var p = plantas.FirstOrDefault(x => x.IdPlanta == oper.IdPlanta.Value);
                                        @p?.Nombre
                                    }
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="Activo" Caption="Activo" Width="100px" />
                        <DxGridDataColumn FieldName="EstadoLaboral" Caption="Estado laboral" Width="120px" />
                        <DxGridDataColumn FieldName="HoraInicioJornada" Caption="Inicio jornada" DisplayFormat="hh':'mm" Width="110px" />
                        <DxGridDataColumn FieldName="HoraFinJornada" Caption="Fin jornada" DisplayFormat="hh':'mm" Width="110px" />
                        <DxGridDataColumn FieldName="Obras" Caption="Per. Obras" Width="110px" Visible="false" />
                        <DxGridDataColumn FieldName="Mensajes" Caption="Per. Mensajes" Width="120px" Visible="false" />
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var oper = (Operario)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3" CaptionPosition="CaptionPosition.Vertical">
                            <DxFormLayoutItem Caption="Nombre Completo" ColSpanMd="6">
                                <DxTextBox @bind-Text="@oper.Nombre" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Teléfono" ColSpanMd="6">
                                <DxTextBox @bind-Text="@oper.Telefono" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Cargo Asignado" ColSpanMd="6" BeginRow="true">
                                <DxComboBox Data="@cargos"
                                            TextFieldName="Descripcion"
                                            ValueFieldName="IdCargo"
                                            @bind-Value="@oper.IdCargo" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Planta Asignada" ColSpanMd="6">
                                <DxComboBox Data="@plantas"
                                            TextFieldName="Nombre"
                                            ValueFieldName="IdPlanta"
                                            @bind-Value="@oper.IdPlanta" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Estado laboral" ColSpanMd="4" BeginRow="true">
                                <DxComboBox Data="@estadosLaborales"
                                            TextFieldName="Text"
                                            ValueFieldName="Value"
                                            @bind-Value="@oper.EstadoLaboral" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Motivo" ColSpanMd="4" Enabled="@IsInactivo(oper)">
                                <DxComboBox Data="@motivosInactividad"
                                            TextFieldName="Text"
                                            ValueFieldName="Value"
                                            @bind-Value="@oper.MotivoInactividad"
                                            ClearButtonVisible="true" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Desde" ColSpanMd="2" Enabled="@IsInactivo(oper)">
                                <DxDateEdit @bind-Date="@oper.InactivoDesde" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Hasta" ColSpanMd="2" Enabled="@IsInactivo(oper)">
                                <DxDateEdit @bind-Date="@oper.InactivoHasta" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Inicio jornada" ColSpanMd="3" BeginRow="true">
                                <DxTimeEdit @bind-Time="@oper.HoraInicioJornada" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Fin jornada" ColSpanMd="3">
                                <DxTimeEdit @bind-Time="@oper.HoraFinJornada" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Máximo diario (minutos)" ColSpanMd="3">
                                <DxSpinEdit @bind-Value="@oper.MinutosMaximosDiarios" MinValue="1" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Máximo semanal (minutos)" ColSpanMd="3">
                                <DxSpinEdit @bind-Value="@oper.MinutosMaximosSemanales" MinValue="1" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3" BeginRow="true">
                                <DxCheckBox @bind-Checked="@oper.TrabajaSabados" LabelPosition="LabelPosition.Right">Trabaja sábados</DxCheckBox>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="3">
                                <DxCheckBox @bind-Checked="@oper.TrabajaDomingos" LabelPosition="LabelPosition.Right">Trabaja domingos</DxCheckBox>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Permisos Especiales" ColSpanMd="12" BeginRow="true" CssClass="border-top pt-2 mt-2 fw-bold text-muted small text-uppercase">
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="4" BeginRow="true">
                                <DxCheckBox @bind-Checked="@oper.Obras" LabelPosition="LabelPosition.Right">Acceso Obras</DxCheckBox>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="4">
                                <DxCheckBox @bind-Checked="@oper.Mensajes" LabelPosition="LabelPosition.Right">Enviar Mensajes</DxCheckBox>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem ColSpanMd="4">
                                <DxCheckBox @bind-Checked="@oper.Tierras" LabelPosition="LabelPosition.Right">Gestión Tierras</DxCheckBox>
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<Operario>? operarios;
    private List<Cargo>? cargos;
    private List<Planta>? plantas;
    private string? errorMessage;

    private sealed class TextValue
    {
        public string Text { get; init; } = string.Empty;
        public string Value { get; init; } = string.Empty;
    }

    private readonly List<TextValue> estadosLaborales =
    [
        new() { Text = "Activo", Value = "Activo" },
        new() { Text = "Inactivo", Value = "Inactivo" }
    ];

    private readonly List<TextValue> motivosInactividad =
    [
        new() { Text = "Baja", Value = "Baja" },
        new() { Text = "Descanso", Value = "Descanso" },
        new() { Text = "Vacaciones", Value = "Vacaciones" },
        new() { Text = "Trámites", Value = "Trámites" },
        new() { Text = "Otros", Value = "Otros" }
    ];

    private static bool IsInactivo(Operario operario) =>
        string.Equals(operario.EstadoLaboral, "Inactivo", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            cargos = await Http.GetFromJsonAsync<List<Cargo>>("api/cargos") ?? new List<Cargo>();
            plantas = await Http.GetFromJsonAsync<List<Planta>>("api/plantas") ?? new List<Planta>();
            operarios = await Http.GetFromJsonAsync<List<Operario>>("api/operarios") ?? new List<Operario>();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar operarios: {ex.Message}";
            cargos ??= new List<Cargo>();
            plantas ??= new List<Planta>();
            operarios ??= new List<Operario>();
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (Operario)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/operarios", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear operario: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/operarios/{editModel.IdOperario}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar operario: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (Operario)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/operarios/{dataItem.IdOperario}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar operario: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }
}

    private async Task OnContactSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (ContlfCliSage50)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            
            editModel.Cliente = (editModel.Cliente ?? "").Trim();
            editModel.Persona = (editModel.Persona ?? "").Trim();
            editModel.Cargo = (editModel.Cargo ?? "").Trim();
            editModel.Telefono = (editModel.Telefono ?? "").Trim();
            editModel.Observa = (editModel.Observa ?? "").Trim();
            editModel.Email = (editModel.Email ?? "").Trim();

            if (e.IsNew)
            {
                // Dynamic Linea calculation
                var nextLinea = (contactos != null && contactos.Any()) ? contactos.Max(c => c.Linea) + 1 : 1;
                editModel.Linea = nextLinea;
                editModel.Cliente = cliente?.Codigo ?? "";
                
                // Add to database
                var response = await Http.PostAsJsonAsync("api/contlfclisage50", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear contacto: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                // Update in database
                var escCliente = Uri.EscapeDataString(editModel.Cliente.Trim());
                var response = await Http.PutAsJsonAsync($"api/contlfclisage50/{escCliente}/{editModel.Linea}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar contacto: {response.ReasonPhrase}";
                    return;
                }
            }

            // If this contact was marked as predeterminado, uncheck others for this client
            if (editModel.Predet && contactos != null)
            {
                foreach (var existing in contactos)
                {
                    if (existing.Linea != editModel.Linea && existing.Predet)
                    {
                        existing.Predet = false;
                        var escCliente = Uri.EscapeDataString(existing.Cliente.Trim());
                        await Http.PutAsJsonAsync($"api/contlfclisage50/{escCliente}/{existing.Linea}", existing);
                    }
                }
            }

            await LoadContactsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar contacto: {ex.Message}";
        }
    }

    private async Task OnContactDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (ContlfCliSage50)e.DataItem;
        try

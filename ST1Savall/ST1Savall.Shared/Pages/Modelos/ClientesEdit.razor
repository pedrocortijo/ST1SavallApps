    private void OnConflictClosed(bool ok)
    {
        showConflictPopup = false;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (cliente == null) return;
        TrimClientFields(cliente);
        
        // Basic validation
        if (string.IsNullOrWhiteSpace(cliente.Codigo))
        {
            errorMessage = "El código de cliente es obligatorio.";
            return;
        }

        if (!HasKeyParams)
        {
            try
            {
                var escCodigo = Uri.EscapeDataString(cliente.Codigo.Trim());
                var checkResponse = await Http.GetAsync($"api/clientessage50/{escCodigo}/");
                if (checkResponse.IsSuccessStatusCode)
                {
                    conflictMessage = $"El código de cliente '{cliente.Codigo}' ya ha sido registrado por otro usuario en este momento. Por favor, asigne otro código o intente de nuevo.";
                    showConflictPopup = true;
                    return;
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error al verificar duplicados: {ex.Message}";
                return;
            }
        }

        try
        {
            await SetupHeadersAsync();
            HttpResponseMessage response;
            if (HasKeyParams)
            {
                var escCodigo = Uri.EscapeDataString(Codigo!.Trim());
                var escClienteerp = Uri.EscapeDataString((Clienteerp ?? "").Trim());
                response = await Http.PutAsJsonAsync($"api/clientessage50/{escCodigo}/{escClienteerp}", cliente);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/clientessage50", cliente);
            }

            if (response.IsSuccessStatusCode)
            {
                GoBack();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                conflictMessage = $"El código de cliente '{cliente.Codigo}' ya ha sido registrado por otro usuario en este momento. Por favor, asigne otro código o intente de nuevo.";
                showConflictPopup = true;
            }
            else
            {
                errorMessage = $"Error al guardar el cliente: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ocurrió un error al guardar: {ex.Message}";
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/modelos/clientes");
    }

    private Task VerEnMapaAsync()
    {
        if (cliente == null) return Task.CompletedTask;
        var query = ST1Savall.MapHelper.BuildNormalizedQuery(cliente.Direccion, cliente.Poblacion, cliente.Provincia, cliente.Codpost);

        if (!string.IsNullOrEmpty(query))
        {
            var backUrl = "/modelos/clientes";
            if (!string.IsNullOrEmpty(Codigo))
            {
                backUrl = $"/modelos/clientes/edit/{Codigo}";
                if (!string.IsNullOrEmpty(Clienteerp))
                {
                    backUrl += $"/{Clienteerp}";
                }
            }
            var mapsUrl = $"/modelos/contenedores/mapa?address={Uri.EscapeDataString(query)}&title={Uri.EscapeDataString(cliente.Nombre ?? "Cliente")}&backUrl={Uri.EscapeDataString(backUrl)}";
            NavigationManager.NavigateTo(mapsUrl);
        }
        else
        {
            errorMessage = "Introduzca una dirección, población o código postal primero para verla en el mapa.";
        }
        return Task.CompletedTask;
    }

@page "/modelos/turnos"
@using ST1Savall.Shared.Data
@inject HttpClient Http

<PageTitle>Turnos</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Turnos</h2>
            <p class="text-muted mb-0">Plantillas de horarios de trabajo.</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm"><i class="oi oi-arrow-left me-1"></i> Volver a Inicio</NavLink>
    </div>

    <div class="card shadow-sm"><div class="card-body p-0">
        <DxGrid @ref="grid" Data="@turnos" KeyFieldName="IdTurno" EditMode="GridEditMode.PopupEditForm"
                EditModelSaving="Save" DataItemDeleting="Delete" ShowSearchBox="true" SearchBoxNullText="Buscar turno..."
                PopupEditFormHeaderCssClass="bg-primary text-white" PopupEditFormHeaderText="Formulario - Turno" PopupEditFormCssClass="crud-popup">
            <Columns>
                <DxGridCommandColumn Width="110px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                    <HeaderTemplate><button class="btn btn-sm btn-primary w-100" @onclick="() => grid?.StartEditNewRowAsync()"><i class="oi oi-plus me-1"></i>Nueva</button></HeaderTemplate>
                    <CellDisplayTemplate>
                        @{ var turno = (Turno)context.DataItem; }
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-primary" title="Editar" @onclick="() => grid?.StartEditDataItemAsync(turno)" @onclick:stopPropagation><i class="oi oi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-info" title="Duplicar" @onclick="() => Duplicar(turno.IdTurno)" @onclick:stopPropagation><i class="oi oi-layers"></i></button>
                            <button class="btn btn-sm btn-outline-danger" title="Eliminar" @onclick="() => grid?.ShowDataItemDeleteConfirmation(turno)" @onclick:stopPropagation><i class="oi oi-trash"></i></button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridCommandColumn>
                <DxGridDataColumn FieldName="NombreTurno" Caption="Turno" />
                <DxGridDataColumn FieldName="HoraEntrada" Caption="Entrada" DisplayFormat="hh':'mm" />
                <DxGridDataColumn FieldName="HoraSalida" Caption="Salida" DisplayFormat="hh':'mm" />
                <DxGridDataColumn FieldName="HoraInicioBreak" Caption="Inicio descanso" DisplayFormat="hh':'mm" />
                <DxGridDataColumn FieldName="HoraFinBreak" Caption="Fin descanso" DisplayFormat="hh':'mm" />
                <DxGridDataColumn FieldName="TotalMinutos" Caption="Total (min)" ReadOnly="true" />
                <DxGridDataColumn FieldName="TotalHoras" Caption="Total (h)" ReadOnly="true" DisplayFormat="n2" />
                <DxGridDataColumn FieldName="ToleranciaEntradaMinutos" Caption="Tolerancia (min)" />
            </Columns>

            <EditFormTemplate Context="ctx">
                @{ var turno = (Turno)ctx.EditModel; }
                
                <DxFormLayout CssClass="w-100 p-3" CaptionPosition="CaptionPosition.Vertical">

                    <DxFormLayoutItem Caption="Descripción del turno" ColSpanMd="12">
                        <DxTextBox @bind-Text="turno.NombreTurno" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Entrada" ColSpanMd="4" BeginRow="true">
                        <DxTimeEdit @bind-Time="turno.HoraEntrada"
                         DisplayFormat="HH:mm" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Salida" ColSpanMd="4">
                        <DxTimeEdit @bind-Time="turno.HoraSalida" 
                        DisplayFormat="HH:mm" />
                    </DxFormLayoutItem>

                        <DxFormLayoutItem Caption="Tolerancia (minutos)" ColSpanMd="4">
                        <DxSpinEdit @bind-Value="turno.ToleranciaEntradaMinutos" BeginRow="true" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                            Almuerzo / Cena / Descanso
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Inicio">
                        <DxTimeEdit @bind-Time="turno.HoraInicioBreak" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Fin">
                        <DxTimeEdit @bind-Time="turno.HoraFinBreak" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanMd="12" CssClass="fw-bold text-primary mt-4 border-bottom pb-2 mb-3" BeginRow="true">
                        Resumen
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Total minutos" ColSpanMd="6">
                        <div class="form-control bg-body-secondary">@turno.TotalMinutos min</div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Total horas" ColSpanMd="6">
                        <div class="form-control bg-body-secondary">@FormatearHoras(turno) h</div>
                    </DxFormLayoutItem>

                </DxFormLayout>
            </EditFormTemplate>
        </DxGrid>
    </div></div>
</div>

@code {
    private IGrid? grid;
    private List<Turno> turnos = [];
    protected override Task OnInitializedAsync() => Load();
    private async Task Load() => turnos = await Http.GetFromJsonAsync<List<Turno>>("api/turnos") ?? [];
    private static string FormatearHoras(Turno turno) => turno.TotalHoras.ToString("0.00");
    private async Task Duplicar(int id) { await Http.PostAsync($"api/turnos/{id}/duplicar", null); await Load(); }
    private async Task Save(GridEditModelSavingEventArgs e) { var turno = (Turno)e.EditModel; if (e.IsNew) await Http.PostAsJsonAsync("api/turnos", turno); else await Http.PutAsJsonAsync($"api/turnos/{turno.IdTurno}", turno); await Load(); }
    private async Task Delete(GridDataItemDeletingEventArgs e) { await Http.DeleteAsync($"api/turnos/{((Turno)e.DataItem).IdTurno}"); await Load(); }
}

@page "/modelos/clientes"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Gestión de Clientes</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Clientes</h2>
            <p class="text-muted mb-0">Administración de clientes de Sage50</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="NavigateToCreate">
                <i class="oi oi-plus me-1"></i> Nuevo Cliente
            </button>
            <NavLink href="/modelos" class="btn btn-outline-secondary btn-sm">
                <i class="oi oi-arrow-left me-1"></i> Volver a Modelos
            </NavLink>
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (clientes == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando clientes...</p>
                </div>
            }
            else
            {
                <DxGrid Data="@clientes"
                        KeyFieldName="Key"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        SearchBoxNullText="Buscar cliente...">
                    <Columns>
                        <DxGridCommandColumn Width="95px" Caption="Acciones" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <CellDisplayTemplate>
                                @{
                                    var item = (ClienteSage50)context.DataItem;
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => NavigateToEdit(item.Codigo, item.Clienteerp)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => ConfirmDelete(item)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="100px" />
                        <DxGridDataColumn FieldName="Nombre" Caption="Nombre Comercial" />
                        <DxGridDataColumn FieldName="Cif" Caption="CIF" Width="120px" />
                        <DxGridDataColumn FieldName="Direccion" Caption="Dirección" />
                        <DxGridDataColumn FieldName="Poblacion" Caption="Población" />
                        <DxGridDataColumn FieldName="Provincia" Caption="Provincia" />
                        <DxGridDataColumn FieldName="BloqCli" Caption="Bloq." Width="80px">
                            <CellDisplayTemplate>
                                @{
                                    var item = (ClienteSage50)context.DataItem;
                                    if (item.BloqCli)
                                    {
                                        <span class="badge bg-danger">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">No</span>
                                    }
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    </Columns>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private List<ClienteSage50>? clientes;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            clientes = await Http.GetFromJsonAsync<List<ClienteSage50>>("api/clientessage50");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar clientes: {ex.Message}";
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/modelos/clientes/edit");
    }

    private void NavigateToEdit(string codigo, string clienteerp)
    {
        var escCodigo = Uri.EscapeDataString(codigo.Trim());
        if (string.IsNullOrWhiteSpace(clienteerp))
        {
            NavigationManager.NavigateTo($"/modelos/clientes/edit/{escCodigo}");
        }
        else
        {
            var escClienteerp = Uri.EscapeDataString(clienteerp.Trim());
            NavigationManager.NavigateTo($"/modelos/clientes/edit/{escCodigo}/{escClienteerp}");
        }
    }

    private async Task ConfirmDelete(ClienteSage50 item)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"¿Está seguro de que desea eliminar al cliente {item.Nombre.Trim()} (Código: {item.Codigo.Trim()})?");
        if (confirmed)
        {
            try
            {
                await SetupHeadersAsync();
                var escCodigo = Uri.EscapeDataString(item.Codigo.Trim());
                var url = $"api/clientessage50/{escCodigo}";
                if (!string.IsNullOrWhiteSpace(item.Clienteerp))
                {
                    url += $"/{Uri.EscapeDataString(item.Clienteerp.Trim())}";
                }
                var response = await Http.DeleteAsync(url);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al borrar cliente: {response.ReasonPhrase}";
                    return;
                }
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error al borrar: {ex.Message}";
            }
        }
    }
}

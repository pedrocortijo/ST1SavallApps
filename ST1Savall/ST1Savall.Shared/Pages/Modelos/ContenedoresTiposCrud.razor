@page "/modelos/contenedores-tipos"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Tipos de Contenedores</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Tipos de Contenedores</h2>
            <p class="text-muted mb-0">Gestión de especificaciones y dimensiones de contenedores</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (tipos == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando tipos...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@tipos"
                        KeyFieldName="IdTipo"
                        EditMode="GridEditMode.PopupEditForm"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormHeaderText="Formulario - Tipo de Contenedor"
                        PopupEditFormCssClass="crud-popup"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true">
                    <Columns>
                        <DxGridCommandColumn Width="80px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nuevo Tipo de Contenedor">
                                    <i class="oi oi-plus me-1"></i> Nuevo
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var tipo = (ContenedorTipo)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(tipo)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(tipo)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="IdTipo" Caption="Código" ReadOnly="true" Width="80px" />
                        <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="25%" />
                        <DxGridDataColumn FieldName="CapacidadMetrosCubicos" Caption="Capacidad (m³)" DisplayFormat="N2" />
                        <DxGridDataColumn FieldName="LargoCm" Caption="Largo (cm)" DisplayFormat="N0" />
                        <DxGridDataColumn FieldName="AnchoCm" Caption="Ancho (cm)" DisplayFormat="N0" />
                        <DxGridDataColumn FieldName="AltoCm" Caption="Alto (cm)" DisplayFormat="N0" />
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var tipo = (ContenedorTipo)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3" CaptionPosition="CaptionPosition.Vertical">
                            <DxFormLayoutItem Caption="Descripción" ColSpanMd="12">
                                <DxTextBox @bind-Text="@tipo.Descripcion" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Capacidad (m³)" ColSpanMd="6" BeginRow="true">
                                <DxSpinEdit @bind-Value="@tipo.CapacidadMetrosCubicos" MinValue="0" MaxValue="1000" Increment="0.1m" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Largo (cm)" ColSpanMd="6">
                                <DxSpinEdit @bind-Value="@tipo.LargoCm" MinValue="0" MaxValue="10000" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Ancho (cm)" ColSpanMd="6" BeginRow="true">
                                <DxSpinEdit @bind-Value="@tipo.AnchoCm" MinValue="0" MaxValue="10000" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Alto (cm)" ColSpanMd="6">
                                <DxSpinEdit @bind-Value="@tipo.AltoCm" MinValue="0" MaxValue="10000" />
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<ContenedorTipo>? tipos;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            tipos = await Http.GetFromJsonAsync<List<ContenedorTipo>>("api/contenedorestipos");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar tipos de contenedores: {ex.Message}";
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (ContenedorTipo)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/contenedorestipos", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear tipo de contenedor: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/contenedorestipos/{editModel.IdTipo}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar tipo de contenedor: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (ContenedorTipo)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/contenedorestipos/{dataItem.IdTipo}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar tipo de contenedor: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }
}

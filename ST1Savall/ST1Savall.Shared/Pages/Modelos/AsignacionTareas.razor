@page "/servicios/asignacion-tareas"
@using ST1Savall.Shared.Data
@using ST1Savall.Shared.Pages.Modelos.Components
@using DevExpress.Blazor
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Asignación de Tareas</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Asignación de Tareas</h2>
            <p class="text-muted mb-0">Seleccione una obra activa y una tarea para generar una solicitud de trabajo directamente</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="p-5 text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando datos...</span>
            </div>
            <p class="mt-2 text-muted mb-0">Cargando obras activas...</p>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Grid de Obras Activas (Izquierda) -->
            <div class="col-lg-9 mb-4">
                <div class="card shadow-sm h-100 border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="fw-bold mb-0">1. Seleccionar Contenedor en Obra</h5>
                    </div>
                    <div class="card-body p-0">
                        <DxGrid Data="@solicitudes"
                                KeyFieldName="IdSolicitud"
                                PagerPosition="GridPagerPosition.Bottom"
                                PageSize="15"
                                AllowSort="true"
                                ShowFilterRow="true"
                                ShowSearchBox="true"
                                SearchBoxNullText="Buscar obra o contenedor..."
                                SelectionMode="GridSelectionMode.Single"
                                AllowSelectRowByClick="true"
                                SelectedDataItem="@selectedSolicitud"
                                SelectedDataItemChanged="OnSelectedSolicitudChanged">
                            <Columns>
                                <DxGridDataColumn FieldName="ObraDescripcion" Caption="Obra / Proyecto" GroupIndex="0" />
                                <DxGridDataColumn FieldName="CodigoEntrega" Caption="Nº Serie Contenedor" Width="180px" />
                                <DxGridDataColumn FieldName="FechaTarea" Caption="Fecha Entrega" DisplayFormat="dd/MM/yyyy" Width="130px" />
                                <DxGridDataColumn FieldName="Observaciones" Caption="Observaciones de la entrega" />
                            </Columns>
                        </DxGrid>
                    </div>
                </div>
            </div>

            <!-- Listado de Tareas y Acción (Derecha) -->
            <div class="col-lg-3 mb-4">
                <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="fw-bold mb-0">2. Tipo de Tarea</h5>
                    </div>
                    <div class="card-body">
                        <FilterRadioListPickerItem TItem="Tarea"
                                                   Data="@filteredTareasList"
                                                   SelectedValue="@selectedTarea"
                                                   SelectedValueChanged="@((Tarea? val) => selectedTarea = val)"
                                                   TextField="@(t => t.NombreTarea)"
                                                   KeyField="@(t => t.IdTarea)"
                                                   SearchPlaceholder="Buscar tarea..."
                                                   MaxHeight="350px" />
                    </div>
                </div>
                
                <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="fw-bold mb-0">3. Crear Solicitud</h5>
                    </div>
                    <div class="card-body text-center py-4">
                        @if (selectedSolicitud != null && selectedTarea != null)
                        {
                            <div class="alert alert-success text-start small mb-3">
                                <strong>Resumen:</strong>
                                <ul class="mb-0 mt-1 pl-3">
                                    <li><strong>Obra:</strong> @GetObraDescripcion(selectedSolicitud.IdCliente)</li>
                                    <li><strong>Cliente:</strong> @selectedSolicitud.NombreCliente</li>
                                    <li><strong>Contenedor:</strong> @selectedSolicitud.CodigoEntrega</li>
                                    <li><strong>Tarea Siguiente:</strong> @selectedTarea.NombreTarea</li>
                                </ul>
                            </div>
                            <button class="btn btn-success btn-lg w-100 shadow d-flex align-items-center justify-content-center gap-2" @onclick="CrearSolicitud">
                                <i class="oi oi-plus"></i> Crear Solicitud
                            </button>
                        }
                        else
                        {
                            <div class="text-muted small py-2">
                                <p class="mb-0">Debe seleccionar un contenedor en la grilla de la izquierda y un tipo de tarea arriba para habilitar la creación de la solicitud.</p>
                            </div>
                            <button class="btn btn-secondary btn-lg w-100 mt-3" disabled>
                                Crear Solicitud
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Obra>? allObras;
    private List<Solicitud>? solicitudes;
    private Solicitud? selectedSolicitud;
    private string? errorMessage;
    private bool isLoading = true;

    private List<Tarea>? allTareasList;
    private List<Tarea>? filteredTareasList;

    private Tarea? selectedTarea;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            await SetupHeadersAsync();
            
            // Load solicitudes with active containers
            solicitudes = await Http.GetFromJsonAsync<List<Solicitud>>("api/solicitudes/con-contenedores");
            allTareasList = await Http.GetFromJsonAsync<List<Tarea>>("api/tareas");
            filteredTareasList = allTareasList;
            
            allObras = await Http.GetFromJsonAsync<List<Obra>>("api/obras");
            if (solicitudes != null && allObras != null)
            {
                foreach (var sol in solicitudes)
                {
                    var obra = allObras.FirstOrDefault(o => o.IdObra == sol.IdCliente);
                    sol.ObraDescripcion = obra != null ? $"{obra.Codigo} - {obra.Descripcion}" : $"Obra ID: {sol.IdCliente}";
                }
            }
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetObraDescripcion(int idCliente)
    {
        var obra = allObras?.FirstOrDefault(o => o.IdObra == idCliente);
        return obra != null ? $"{obra.Codigo} - {obra.Descripcion}" : $"Obra ID: {idCliente}";
    }

    private async Task OnSelectedSolicitudChanged(object? val)
    {
        var sol = val as Solicitud;
        selectedSolicitud = sol;
        selectedTarea = null; // Reset selection
        
        if (sol == null)
        {
            filteredTareasList = allTareasList;
            StateHasChanged();
            return;
        }

        try
        {
            filteredTareasList = await Http.GetFromJsonAsync<List<Tarea>>($"api/tareas/{sol.IdTipoTarea}/siguientes");
        }
        catch (Exception ex)
        {
            filteredTareasList = allTareasList;
            Console.WriteLine($"Error al obtener tareas siguientes: {ex.Message}");
        }
        StateHasChanged();
    }

    private void CrearSolicitud()
    {
        if (selectedSolicitud == null || selectedTarea == null) return;
        NavigationManager.NavigateTo($"/modelos/solicitudes/edit?ObraId={selectedSolicitud.IdCliente}&TareaId={selectedTarea.IdTarea}&ContenedorCodigo={selectedSolicitud.CodigoEntrega}");
    }
}

@page "/servicios/asignacion-tareas"
@using ST1Savall.Shared.Data
@using DevExpress.Blazor
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Asignación de Tareas</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Asignación de Tareas</h2>
            <p class="text-muted mb-0">Seleccione una obra activa y una tarea para generar una solicitud de trabajo directamente</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="p-5 text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando datos...</span>
            </div>
            <p class="mt-2 text-muted mb-0">Cargando obras activas...</p>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Grid de Obras Activas (Izquierda) -->
            <div class="col-lg-8 mb-4">
                <div class="card shadow-sm h-100 border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="fw-bold mb-0">1. Seleccionar Obra Activa</h5>
                    </div>
                    <div class="card-body p-0">
                        <DxGrid Data="@activeObras"
                                KeyFieldName="IdObra"
                                PagerPosition="GridPagerPosition.Bottom"
                                PageSize="15"
                                AllowSort="true"
                                ShowFilterRow="true"
                                ShowSearchBox="true"
                                SearchBoxNullText="Buscar obra..."
                                SelectionMode="GridSelectionMode.Single"
                                AllowSelectRowByClick="true"
                                SelectedDataItemChanged="@((object val) => selectedObra = (Obra)val)">
                            <Columns>
                                <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="95px" />
                                <DxGridDataColumn FieldName="Descripcion" Caption="Nombre de la Obra" />
                                <DxGridDataColumn FieldName="NombreCliente" Caption="Cliente" />
                                <DxGridDataColumn FieldName="Ubicacion" Caption="Dirección" />
                                <DxGridDataColumn FieldName="Poblacion" Caption="Población" />
                                <DxGridDataColumn Caption="Última Tarea" Width="130px">
                                    <CellDisplayTemplate>
                                        @{
                                            var obra = (Obra)context.DataItem;
                                            <span>@GetLatestTareaText(obra.IdObra)</span>
                                        }
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Contenedor" Width="160px">
                                    <CellDisplayTemplate>
                                        @{
                                            var obra = (Obra)context.DataItem;
                                            <span>@GetLatestContenedorText(obra.IdObra)</span>
                                        }
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGrid>
                    </div>
                </div>
            </div>

            <!-- Listado de Tareas y Acción (Derecha) -->
            <div class="col-lg-4 mb-4">
                <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="fw-bold mb-0">2. Seleccionar Tipo de Tarea</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var tarea in tareasList)
                            {
                                <button type="button" 
                                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 @(selectedTarea?.Id == tarea.Id ? "active" : "")"
                                        @onclick="() => selectedTarea = tarea">
                                    <span class="fw-semibold">@tarea.Name</span>
                                    @if (selectedTarea?.Id == tarea.Id)
                                    {
                                        <i class="oi oi-check text-white"></i>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                </div>
                
                <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="fw-bold mb-0">3. Crear Solicitud</h5>
                    </div>
                    <div class="card-body text-center py-4">
                        @if (selectedObra != null && selectedTarea != null)
                        {
                            <div class="alert alert-success text-start small mb-3">
                                <strong>Resumen de Asignación:</strong>
                                <ul class="mb-0 mt-1 pl-3">
                                    <li><strong>Obra:</strong> @selectedObra.Descripcion (@selectedObra.Codigo)</li>
                                    <li><strong>Cliente:</strong> @selectedObra.NombreCliente</li>
                                    <li><strong>Tarea:</strong> @selectedTarea.Value.Name</li>
                                </ul>
                            </div>
                            <button class="btn btn-success btn-lg w-100 shadow d-flex align-items-center justify-content-center gap-2" @onclick="CrearSolicitud">
                                <i class="oi oi-plus"></i> Crear y Abrir Solicitud
                            </button>
                        }
                        else
                        {
                            <div class="text-muted small py-2">
                                <p class="mb-0">Debe seleccionar una obra de la grilla de la izquierda y un tipo de tarea arriba para habilitar la creación de la solicitud.</p>
                            </div>
                            <button class="btn btn-secondary btn-lg w-100 mt-3" disabled>
                                Crear Solicitud
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Obra>? activeObras;
    private List<Solicitud>? solicitudes;
    private Obra? selectedObra;
    private string? errorMessage;
    private bool isLoading = true;

    private struct KeyName { public int Id; public string Name; }

    private List<KeyName> tareasList = new()
    {
        new() { Id = 1, Name = "Entrega" },
        new() { Id = 2, Name = "Recogida" },
        new() { Id = 3, Name = "Sustitución" }
    };

    private KeyName? selectedTarea;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            await SetupHeadersAsync();
            
            // Load all solicitudes to calculate last tasks and containers
            solicitudes = await Http.GetFromJsonAsync<List<Solicitud>>("api/solicitudes");
            
            var allObras = await Http.GetFromJsonAsync<List<Obra>>("api/obras");
            if (allObras != null)
            {
                activeObras = allObras.Where(o => o.Finalizada != true).ToList();
            }
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private Solicitud? GetLatestSolicitud(int idObra)
    {
        if (solicitudes == null) return null;
        return solicitudes
            .Where(s => s.IdCliente == idObra)
            .OrderByDescending(s => s.FechaSolicitud ?? DateTime.MinValue)
            .ThenByDescending(s => s.IdSolicitud)
            .FirstOrDefault();
    }

    private string GetLatestTareaText(int idObra)
    {
        var latest = GetLatestSolicitud(idObra);
        if (latest == null) return "-";
        return latest.IdTipoTarea == 1 ? "Entrega" : latest.IdTipoTarea == 2 ? "Recogida" : "Sustitución";
    }

    private string GetLatestContenedorText(int idObra)
    {
        var latest = GetLatestSolicitud(idObra);
        if (latest == null) return "-";
        
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(latest.CodigoEntrega))
            parts.Add(latest.CodigoEntrega);
        if (!string.IsNullOrWhiteSpace(latest.CodigoRecogida))
            parts.Add(latest.CodigoRecogida);
            
        return parts.Count > 0 ? string.Join(" / ", parts) : "-";
    }

    private void CrearSolicitud()
    {
        if (selectedObra == null || selectedTarea == null) return;
        NavigationManager.NavigateTo($"/modelos/solicitudes/edit?ObraId={selectedObra.IdObra}&TareaId={selectedTarea.Value.Id}");
    }
}

@page "/servicios/planificacion"
@using ST1Savall.Shared.Data
@using DevExpress.Blazor
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Planificación de servicios</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold text-primary mb-1">Planificación de servicios</h2>
            <p class="text-muted mb-0">Agenda diaria y semanal agrupada por conductor</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="LoadDataAsync">
                <i class="oi oi-reload me-1"></i> Actualizar
            </button>
            <NavLink href="/modelos/solicitudes" class="btn btn-outline-secondary btn-sm">
                <i class="oi oi-arrow-left me-1"></i> Volver a Solicitudes
            </NavLink>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (loading)
    {
        <div class="p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Cargando planificación...</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="text-muted small">Servicios planificados</div>
                        <div class="fs-3 fw-bold text-primary">@serviciosPlanificados.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="text-muted small">Horas planificadas</div>
                        <div class="fs-3 fw-bold text-success">@(serviciosPlanificados.Sum(s => s.DuracionPlanificadaMinutos ?? 0) / 60d) h</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="text-muted small">Solicitudes sin horario</div>
                        <div class="fs-3 fw-bold text-warning">@solicitudesSinPlanificar.Count</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header d-flex justify-content-between align-items-center py-3">
                <h5 class="fw-bold mb-0">Calendario por conductor</h5>
                <span class="text-muted small">Los servicios anulados no consumen disponibilidad</span>
            </div>
            <div class="card-body p-2">
                <DxScheduler StartDate="@DateTime.Today"
                             DataStorage="@schedulerDataStorage"
                             GroupType="SchedulerGroupType.Resource"
                             AllowCreateAppointment="false"
                             AllowEditAppointment="false"
                             AllowDeleteAppointment="false"
                             AllowDragAppointment="false"
                             AllowResizeAppointment="false"
                             AllowDragAppointmentBetweenResources="false">
                    <Views>
                        <DxSchedulerDayView />
                        <DxSchedulerWorkWeekView />
                        <DxSchedulerTimelineView />
                    </Views>
                </DxScheduler>
            </div>
        </div>

        @if (solicitudesSinPlanificar.Count > 0)
        {
            <div class="card shadow-sm border-0">
                <div class="card-header py-3">
                    <h5 class="fw-bold mb-0">Pendientes de planificar</h5>
                </div>
                <div class="card-body p-0">
                    <DxGrid Data="@solicitudesSinPlanificar" KeyFieldName="IdSolicitud" PageSize="10" ShowSearchBox="true">
                        <Columns>
                            <DxGridDataColumn Caption="Acción" Width="90px">
                                <CellDisplayTemplate>
                                    @{
                                        var solicitud = (Solicitud)context.DataItem;
                                    }
                                    <button class="btn btn-sm btn-primary" @onclick="() => EditarSolicitud(solicitud.IdSolicitud)">Planificar</button>
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn FieldName="NombreObra" Caption="Obra" />
                            <DxGridDataColumn FieldName="NombreCliente" Caption="Cliente" />
                            <DxGridDataColumn FieldName="FechaTarea" Caption="Fecha solicitada" DisplayFormat="dd/MM/yyyy" />
                            <DxGridDataColumn FieldName="EstadoDescripcion" Caption="Estado" />
                        </Columns>
                    </DxGrid>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool loading = true;
    private string? errorMessage;
    private List<Solicitud> serviciosPlanificados = [];
    private List<Solicitud> solicitudesSinPlanificar = [];
    private List<Operario> conductores = [];
    private List<EstadoSolicitud> estados = [];
    private DxSchedulerDataStorage schedulerDataStorage = new();

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
    }

    private async Task LoadDataAsync()
    {
        try
        {
            loading = true;
            errorMessage = null;
            var solicitudes = await Http.GetFromJsonAsync<List<Solicitud>>("api/solicitudes") ?? [];
            conductores = (await Http.GetFromJsonAsync<List<Operario>>("api/operarios") ?? [])
                .OrderBy(o => o.Nombre)
                .ToList();
            estados = await Http.GetFromJsonAsync<List<EstadoSolicitud>>("api/estadosSolicitud") ?? [];

            foreach (var solicitud in solicitudes)
                solicitud.EstadoDescripcion = estados.FirstOrDefault(e => e.IdEstado == solicitud.Estado)?.Descripcion;

            serviciosPlanificados = solicitudes
                .Where(s => s.Estado != 6 && s.IdConductor.HasValue && s.FechaHoraInicioPlanificada.HasValue && s.FechaHoraFinPlanificada.HasValue)
                .ToList();
            solicitudesSinPlanificar = solicitudes
                .Where(s => s.Estado != 6 && (!s.IdConductor.HasValue || !s.FechaHoraInicioPlanificada.HasValue || !s.FechaHoraFinPlanificada.HasValue))
                .OrderBy(s => s.FechaTarea ?? DateTime.MaxValue)
                .ToList();

            schedulerDataStorage = new DxSchedulerDataStorage
            {
                AppointmentsSource = serviciosPlanificados,
                AppointmentMappings = new DxSchedulerAppointmentMappings
                {
                    Id = "IdSolicitud",
                    Start = "FechaHoraInicioPlanificada",
                    End = "FechaHoraFinPlanificada",
                    Subject = "NombreObra",
                    Description = "Observaciones",
                    Location = "PoblacionCliente",
                    ResourceId = "IdConductor"
                },
                ResourcesSource = conductores,
                ResourceMappings = new DxSchedulerResourceMappings
                {
                    Id = "IdOperario",
                    Caption = "Nombre"
                }
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo cargar la planificación: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void EditarSolicitud(int id) => NavigationManager.NavigateTo($"/modelos/solicitudes/edit/{id}");
}

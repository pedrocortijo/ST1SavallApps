@page "/modelos/horarios-operarios"
@using ST1Savall.Shared.Data
@inject HttpClient Http
<PageTitle>Horarios de operarios</PageTitle>
<h2 class="fw-bold text-primary">Horarios de operarios</h2>
<p class="text-muted">Asignación de turnos por día y periodo de vigencia.</p>
<DxGrid Data="@horarios" KeyFieldName="IdAsignacion" EditMode="GridEditMode.PopupEditForm" EditModelSaving="Save" DataItemDeleting="Delete" ShowSearchBox="true">
 <Columns><DxGridCommandColumn NewButtonVisible="true" EditButtonVisible="true" DeleteButtonVisible="true" /><DxGridDataColumn FieldName="IdOperario" Caption="Operario"><CellDisplayTemplate>@operarios.FirstOrDefault(o=>o.IdOperario==((HorarioOperario)context.DataItem).IdOperario)?.Nombre</CellDisplayTemplate></DxGridDataColumn><DxGridDataColumn FieldName="IdTurno" Caption="Turno"><CellDisplayTemplate>@turnos.FirstOrDefault(t=>t.IdTurno==((HorarioOperario)context.DataItem).IdTurno)?.NombreTurno</CellDisplayTemplate></DxGridDataColumn><DxGridDataColumn FieldName="DiaSemana" Caption="Día" /><DxGridDataColumn FieldName="FechaInicioVigencia" Caption="Desde" /><DxGridDataColumn FieldName="FechaFinVigencia" Caption="Hasta" /></Columns>
 <EditFormTemplate Context="ctx">@{var h=(HorarioOperario)ctx.EditModel;}<DxFormLayout CssClass="p-3"><DxFormLayoutItem Caption="Operario"><DxComboBox Data="@operarios" TextFieldName="Nombre" ValueFieldName="IdOperario" @bind-Value="h.IdOperario" /></DxFormLayoutItem><DxFormLayoutItem Caption="Turno"><DxComboBox Data="@turnos" TextFieldName="NombreTurno" ValueFieldName="IdTurno" @bind-Value="h.IdTurno" /></DxFormLayoutItem><DxFormLayoutItem Caption="Día (1=Lunes)"><DxSpinEdit @bind-Value="h.DiaSemana" MinValue="1" MaxValue="7" /></DxFormLayoutItem><DxFormLayoutItem Caption="Desde"><DxDateEdit @bind-Date="h.FechaInicioVigencia" /></DxFormLayoutItem><DxFormLayoutItem Caption="Hasta"><DxDateEdit @bind-Date="h.FechaFinVigencia" /></DxFormLayoutItem></DxFormLayout></EditFormTemplate>
</DxGrid>
@code {List<HorarioOperario> horarios=[];List<Operario> operarios=[];List<Turno> turnos=[];protected override async Task OnInitializedAsync(){horarios=await Http.GetFromJsonAsync<List<HorarioOperario>>("api/horariosoperarios")??[];operarios=await Http.GetFromJsonAsync<List<Operario>>("api/operarios")??[];turnos=await Http.GetFromJsonAsync<List<Turno>>("api/turnos")??[];}async Task Save(GridEditModelSavingEventArgs e){var h=(HorarioOperario)e.EditModel;if(e.IsNew)await Http.PostAsJsonAsync("api/horariosoperarios",h);else await Http.PutAsJsonAsync($"api/horariosoperarios/{h.IdAsignacion}",h);horarios=await Http.GetFromJsonAsync<List<HorarioOperario>>("api/horariosoperarios")??[];}async Task Delete(GridDataItemDeletingEventArgs e){await Http.DeleteAsync($"api/horariosoperarios/{((HorarioOperario)e.DataItem).IdAsignacion}");horarios=await Http.GetFromJsonAsync<List<HorarioOperario>>("api/horariosoperarios")??[];}}

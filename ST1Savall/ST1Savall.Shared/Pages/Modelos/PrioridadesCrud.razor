@page "/modelos/prioridades"
@using ST1Savall.Shared.Data
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Gestión de Prioridades</PageTitle>

<div class="container-fluid py-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Prioridades</h2>
            <p class="text-muted mb-0">Administración de prioridades.</p>
        </div>
        <NavLink href="/" class="btn btn-outline-secondary btn-sm">
            <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
        </NavLink>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (prioridades == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando prioridades...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@prioridades"
                        KeyFieldName="IdPrioridad"
                        EditMode="GridEditMode.PopupEditForm"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormCssClass="crud-popup"
                        PopupEditFormHeaderText="Formulario de Prioridad"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        SearchBoxNullText="Buscar prioridad...">
                    <Columns>
                        <DxGridCommandColumn Width="80px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nueva Prioridad">
                                    <i class="oi oi-plus me-1"></i> Nueva
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var prioridad = (Prioridad)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(prioridad)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(prioridad)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="IdPrioridad" Caption="ID" ReadOnly="true" Width="75px" />
                        <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="90px" />
                        <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" />
                        <DxGridDataColumn FieldName="BgColor" Caption="Color Fondo" Width="150px">
                            <CellDisplayTemplate>
                                <div class="d-flex align-items-center">
                                    <div class="border me-2" style="width: 20px; height: 20px; background-color: @context.Value; border-radius: 4px;"></div>
                                    <span>@context.Value</span>
                                </div>
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="TextColor" Caption="Color Texto" Width="150px">
                            <CellDisplayTemplate>
                                <div class="d-flex align-items-center">
                                    <div class="border me-2" style="width: 20px; height: 20px; background-color: @context.Value; border-radius: 4px;"></div>
                                    <span>@context.Value</span>
                                </div>
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn Caption="Vista Previa" Width="160px">
                            <CellDisplayTemplate>
                                @{
                                    var pri = (Prioridad)context.DataItem;
                                }
                                <div class="text-center py-1 px-2 border" style="background-color: @pri.BgColor; color: @pri.TextColor; border-radius: 4px; font-weight: bold; font-size: 0.8rem;">
                                    @pri.Descripcion
                                </div>
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var pri = (Prioridad)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3">
                            <DxFormLayoutItem Caption="Código" ColSpanMd="12">
                                <DxSpinEdit @bind-Value="@pri.Codigo" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Descripción" ColSpanMd="12">
                                <DxTextBox @bind-Text="@pri.Descripcion" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Color Fondo" ColSpanMd="6">
                                <div class="d-flex gap-2 align-items-center">
                                    <DxTextBox @bind-Text="@pri.BgColor" />
                                    <input type="color" @bind="@pri.BgColor" style="height: 38px; width: 45px; padding: 2px; border: 1px solid #ced4da; border-radius: 4px; cursor: pointer;" />
                                </div>
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Color Texto" ColSpanMd="6">
                                <div class="d-flex gap-2 align-items-center">
                                    <DxTextBox @bind-Text="@pri.TextColor" />
                                    <input type="color" @bind="@pri.TextColor" style="height: 38px; width: 45px; padding: 2px; border: 1px solid #ced4da; border-radius: 4px; cursor: pointer;" />
                                </div>
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<Prioridad>? prioridades;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            prioridades = await Http.GetFromJsonAsync<List<Prioridad>>("api/prioridades");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar prioridades: {ex.Message}";
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (Prioridad)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/prioridades", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear prioridad: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/prioridades/{editModel.IdPrioridad}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar prioridad: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (Prioridad)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/prioridades/{dataItem.IdPrioridad}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar prioridad: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }
}

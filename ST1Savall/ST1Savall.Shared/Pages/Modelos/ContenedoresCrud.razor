@page "/modelos/contenedores"
@using ST1Savall.Shared.Data
@using System.Globalization
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Contenedores</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Contenedores</h2>
            <p class="text-muted mb-0">Gestión de unidades físicas de contenedores y sus estados actuales</p>
        </div>
        <div class="d-flex gap-2">
            <NavLink href="/modelos/contenedores/mapa" class="btn btn-outline-primary btn-sm">
                <i class="oi oi-map-marker me-1"></i> Ubicaciones Contenedores
            </NavLink>
            <NavLink href="/" class="btn btn-outline-secondary btn-sm">
                <i class="oi oi-arrow-left me-1"></i> Volver a Inicio
            </NavLink>
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (contenedores == null || tipos == null)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Cargando contenedores y tipos...</p>
                </div>
            }
            else
            {
                <DxGrid @ref="grid"
                        Data="@contenedores"
                        KeyFieldName="IdContenedor"
                        EditMode="GridEditMode.PopupEditForm"
                        EditModelSaving="OnEditModelSaving"
                        DataItemDeleting="OnDataItemDeleting"
                        PopupEditFormHeaderText="Formulario - Contenedor"
                        PopupEditFormHeaderCssClass="bg-primary text-white"
                        PopupEditFormCssClass="crud-popup"                        
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSize="20"
                        AllowSort="true"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        AutoExpandAllGroupRows="true"
                        CustomizeElement="OnCustomizeElement">
                    <Columns>
                        <DxGridCommandColumn Width="80px" NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                            <HeaderTemplate>
                                <button class="btn btn-sm btn-primary d-flex align-items-center justify-content-center shadow-sm w-100" 
                                        @onclick="() => grid?.StartEditNewRowAsync()"
                                        title="Nuevo Contenedor">
                                    <i class="oi oi-plus me-1"></i> Nuevo
                                </button>
                            </HeaderTemplate>
                            <CellDisplayTemplate>
                                @{
                                    var cont = (Contenedor)context.DataItem;
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.StartEditDataItemAsync(cont)" 
                                                @onclick:stopPropagation
                                                title="Editar">
                                            <i class="oi oi-pencil" style="font-size: 0.9rem;"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center shadow-sm" 
                                                style="width: 32px; height: 32px;"
                                                @onclick="() => grid?.ShowDataItemDeleteConfirmation(cont)" 
                                                @onclick:stopPropagation
                                                title="Eliminar">
                                            <i class="oi oi-trash" style="font-size: 0.9rem;"></i>
                                        </button>
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridCommandColumn>
                        <DxGridDataColumn FieldName="NumSerie" Caption="Número de Serie" Width="15%" />
                        <DxGridDataColumn FieldName="Tipo.Descripcion" Caption="Tipo de Contenedor" Width="35%" TextAlignment="GridTextAlignment.Left" GroupIndex="0">
                            <CellDisplayTemplate>
                                @{
                                    var cont = (Contenedor)context.DataItem;
                                    var t = tipos.FirstOrDefault(x => x.IdTipo == cont.IdTipo);
                                    @t?.Descripcion
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="ObraActual" Caption="Ubicación / Obra" Width="30%">
                            <CellDisplayTemplate>
                                @{
                                    var cont = (Contenedor)context.DataItem;
                                    var sol = solicitudesConContenedores?.FirstOrDefault(s => s.CodigoEntrega == cont.NumSerie);
                                    <div class="d-flex align-items-center justify-content-between gap-2">
                                        <span>@cont.ObraActual</span>
                                        @if (sol != null)
                                        {
                                            var mapsUrl = GetMapsUrl(sol);
                                            @if (!string.IsNullOrEmpty(mapsUrl))
                                            {
                                                <a href="@mapsUrl" class="btn btn-sm btn-outline-success p-1 d-inline-flex align-items-center justify-content-center shadow-sm" 
                                                   style="width: 28px; height: 28px;" title="Ver en Mapa" @onclick:stopPropagation>
                                                    <i class="oi oi-map-marker" style="font-size: 0.85rem;"></i>
                                                </a>
                                            }
                                        }
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="EstadoFisico" Caption="Estado" />
                        <DxGridDataColumn FieldName="UltimaRevision" Caption="Última Revisión" DisplayFormat="dd/MM/yyyy" />
                    </Columns>
                    <EditFormTemplate Context="EditFormContext">
                        @{
                            var cont = (Contenedor)EditFormContext.EditModel;
                        }
                        <DxFormLayout CssClass="w-100 p-3" CaptionPosition="CaptionPosition.Vertical">
                            <DxFormLayoutItem Caption="Número de Serie" ColSpanMd="6">
                                <DxTextBox @bind-Text="@cont.NumSerie" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Tipo de Contenedor" ColSpanMd="6">
                                <DxComboBox Data="@tipos"
                                            TextFieldName="Descripcion"
                                            ValueFieldName="IdTipo"
                                            @bind-Value="@cont.IdTipo" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Estado" ColSpanMd="6" BeginRow="true">
                                <DxComboBox Data="@estados"
                                            @bind-Value="@cont.EstadoFisico" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Última Revisión" ColSpanMd="6">
                                <DxDateEdit @bind-Date="@cont.UltimaRevision" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Observaciones" ColSpanMd="12" BeginRow="true">
                                <DxTextBox @bind-Text="@cont.Observaciones" />
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    </EditFormTemplate>
                </DxGrid>
            }
        </div>
    </div>
</div>

@code {
    private IGrid? grid;
    private List<Contenedor>? contenedores;
    private List<ContenedorTipo>? tipos;
    private List<Obra>? obras;
    private List<Solicitud>? solicitudesConContenedores;
    private string? errorMessage;

    private List<string> estados = new() { "Disponible", "Entregado", "En Reparacion", "Baja" };

    protected override async Task OnInitializedAsync()
    {
        await SetupHeadersAsync();
        await LoadDataAsync();
    }

    private async Task SetupHeadersAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var token = authState.User.FindFirst("token")?.Value;
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            tipos = await Http.GetFromJsonAsync<List<ContenedorTipo>>("api/contenedorestipos");
            contenedores = await Http.GetFromJsonAsync<List<Contenedor>>("api/contenedores");
            obras = await Http.GetFromJsonAsync<List<Obra>>("api/obras");
            
            try
            {
                solicitudesConContenedores = await Http.GetFromJsonAsync<List<Solicitud>>("api/solicitudes/con-contenedores");
            }
            catch
            {
                solicitudesConContenedores = new List<Solicitud>();
            }

            if (contenedores != null)
            {
                foreach (var cont in contenedores)
                {
                    var sol = solicitudesConContenedores?.FirstOrDefault(s => s.CodigoEntrega == cont.NumSerie);
                    if (sol != null)
                    {
                        cont.ObraActual = sol.NombreObra ?? "Obra sin nombre";
                    }
                    else
                    {
                        cont.ObraActual = cont.EstadoFisico == "Disponible" ? "En Almacén" : "-";
                    }
                }
            }

            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar contenedores: {ex.Message}";
        }
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var editModel = (Contenedor)e.EditModel;
        try
        {
            await SetupHeadersAsync();
            if (e.IsNew)
            {
                var response = await Http.PostAsJsonAsync("api/contenedores", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al crear contenedor: {response.ReasonPhrase}";
                    return;
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/contenedores/{editModel.IdContenedor}", editModel);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al actualizar contenedor: {response.ReasonPhrase}";
                    return;
                }
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var dataItem = (Contenedor)e.DataItem;
        try
        {
            await SetupHeadersAsync();
            var response = await Http.DeleteAsync($"api/contenedores/{dataItem.IdContenedor}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error al borrar contenedor: {response.ReasonPhrase}";
                return;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al borrar: {ex.Message}";
        }
    }

    private void OnCustomizeElement(GridCustomizeElementEventArgs e)
    {
        if (e.ElementType == GridElementType.DataRow)
        {
            var estado = e.Grid.GetRowValue(e.VisibleIndex, "EstadoFisico") as string;
            if (estado == "Disponible")
            {
                e.CssClass = "row-disponible";
            }
        }
    }

    private string GetMapsUrl(Solicitud sol)
    {
        double? lat = null;
        double? lon = null;
        string? query = null;

        // 1. Prioritize coordinates
        if (sol.Latitud.HasValue && sol.Longitud.HasValue)
        {
            lat = (double)sol.Latitud.Value;
            lon = (double)sol.Longitud.Value;
        }
        else if (!string.IsNullOrWhiteSpace(sol.CoordenadasGPS))
        {
            var parts = sol.CoordenadasGPS.Split(',');
            if (parts.Length == 2 && 
                double.TryParse(parts[0].Trim(), NumberStyles.Any, CultureInfo.InvariantCulture, out var parsedLat) && 
                double.TryParse(parts[1].Trim(), NumberStyles.Any, CultureInfo.InvariantCulture, out var parsedLon))
            {
                lat = parsedLat;
                lon = parsedLon;
            }
        }

        // 2. Fallback to Obra location details
        var obra = obras?.FirstOrDefault(o => o.IdObra == sol.IdCliente);
        if (obra != null)
        {
            query = ST1Savall.MapHelper.BuildNormalizedQuery(obra.Ubicacion, obra.Poblacion, null, obra.CodigoPostal);
        }

        // 3. Last fallback: Solicitud's own address details
        if (string.IsNullOrEmpty(query))
        {
            query = ST1Savall.MapHelper.BuildNormalizedQuery(sol.DireccionCliente, sol.PoblacionCliente, null, null);
        }

        if (string.IsNullOrEmpty(query))
        {
            query = "Dirección no especificada";
        }

        var latParam = lat.HasValue ? $"&lat={lat.Value.ToString(CultureInfo.InvariantCulture)}" : "";
        var lonParam = lon.HasValue ? $"&lon={lon.Value.ToString(CultureInfo.InvariantCulture)}" : "";
        
        return $"/modelos/contenedores/mapa?address={Uri.EscapeDataString(query)}&title={Uri.EscapeDataString(sol.NombreObra ?? "Ubicación de Contenedor")}{latParam}{lonParam}&backUrl={Uri.EscapeDataString("/modelos/contenedores")}";
    }
}

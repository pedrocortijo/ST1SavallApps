<div id="sidebar">
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="/" Text="Inicio" CssClass="menu-item" IconCssClass="icon home-icon"></DxMenuItem>
            
            <DxMenuItem Text="Maestros" CssClass="menu-item" IconCssClass="icon database-icon">
                <Items>
                    <DxMenuItem NavigateUrl="/modelos/contenedores" Text="Contenedores" CssClass="menu-item" IconCssClass="icon contenedores-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/contenedores-tipos" Text="Tipos de contenedores" CssClass="menu-item" IconCssClass="icon tipos-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/obrasmnto" Text="Obras" CssClass="menu-item" IconCssClass="icon obras-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/clientes" Text="Clientes" CssClass="menu-item" IconCssClass="icon operarios-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/operarios" Text="Operarios" CssClass="menu-item" IconCssClass="icon operarios-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/cargos" Text="Cargos" CssClass="menu-item" IconCssClass="icon cargos-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/estados" Text="Estados" CssClass="menu-item" IconCssClass="icon status-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/prioridades" Text="Prioridades" CssClass="menu-item" IconCssClass="icon status-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/tareas" Text="Tareas" CssClass="menu-item" IconCssClass="icon tareas-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/tareas-relaciones" Text="Relaciones de tareas" CssClass="menu-item" IconCssClass="icon status-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/poblaciones" Text="Poblaciones" CssClass="menu-item" IconCssClass="icon status-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/modelos/plantas" Text="Plantas" CssClass="menu-item" IconCssClass="icon status-icon"></DxMenuItem>
                </Items>
            </DxMenuItem>

            <DxMenuItem Text="Servicios" CssClass="menu-item" IconCssClass="icon doc-icon">
                <Items>
                    <DxMenuItem NavigateUrl="/modelos/solicitudes" Text="Solicitudes" CssClass="menu-item" IconCssClass="icon solicitudes-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/servicios/asignacion-tareas" Text="Asignación de tareas" CssClass="menu-item" IconCssClass="icon tareas-icon"></DxMenuItem>
                    <DxMenuItem NavigateUrl="/servicios/informes" Text="Informes" CssClass="menu-item" IconCssClass="icon chart-icon"></DxMenuItem>
                </Items>
            </DxMenuItem>

            <DxMenuItem NavigateUrl="@ManageUrl" Text="Configuración" CssClass="menu-item" IconCssClass="icon settings-icon"></DxMenuItem>
        </Items>
    </DxMenu>
    
    <div class="theme-selector-container px-3 py-2 mt-4" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <label class="text-white-50 small mb-1 d-block" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Tema Visual</label>
        <DxComboBox Data="@availableThemes"
                    TextFieldName="Name"
                    ValueFieldName="Id"
                    Value="@selectedTheme"
                    ValueChanged="@((string t) => OnThemeChanged(t))"
                    CssClass="w-100" />
    </div>
</div>
 
@inject ST1Savall.Shared.Services.IFormFactor FormFactor
@inject IJSRuntime JSRuntime
 
@code {
    private string ManageUrl => FormFactor.GetPlatform() == "Web" ? "login" : "settings";

    private List<ThemeInfo> availableThemes = new()
    {
        new() { Id = "blazing-berry", Name = "Blazing Berry" },
        new() { Id = "blazing-dark", Name = "Blazing Dark" },
        new() { Id = "office-white", Name = "Office White" },
        new() { Id = "purple", Name = "Purple" },
        new() { Id = "fluent-light", Name = "Fluent Light" },
        new() { Id = "fluent-dark", Name = "Fluent Dark" }
    };
    private string selectedTheme = "blazing-berry";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var cookieTheme = await JSRuntime.InvokeAsync<string>("getTheme");
                if (!string.IsNullOrEmpty(cookieTheme) && availableThemes.Any(t => t.Id == cookieTheme))
                {
                    selectedTheme = cookieTheme;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task OnThemeChanged(string theme)
    {
        selectedTheme = theme;
        await JSRuntime.InvokeVoidAsync("setTheme", theme);
    }

    public class ThemeInfo
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }
}
